<section
  class="split-hero"
  style="--split-accent: {{ section.settings.accent_color }};"
>
  <div class="split-hero__inner{% if section.settings.image_position == 'left' %} split-hero__inner--flip{% endif %}">

    {%- comment -%} Left: Text content {%- endcomment -%}
    <div class="split-hero__content">

      {%- if section.settings.eyebrow != blank -%}
        <p class="split-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h2 class="split-hero__heading">
        {%- if section.settings.heading_static != blank -%}
          <span class="split-hero__heading-block">{{ section.settings.heading_static }}</span>
        {%- endif -%}
        
        <span class="split-hero__typewriter-container">
          <span id="Typewriter-{{ section.id }}" class="split-hero__typewriter-text" data-words='{{ section.settings.typewriter_words }}'></span>
          <span class="split-hero__cursor">|</span>
        </span>
      </h2>

      {%- if section.settings.description != blank -%}
        <p class="split-hero__description">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="split-hero__bottom">

        {%- if section.settings.cta_label != blank -%}
          <a
            href="{{ section.settings.cta_url | default: '#' }}"
            class="split-hero__cta"
          >
            <span>{{ section.settings.cta_label }}</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 12L12 2M12 2H4M12 2v8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}

        {%- liquid
          assign has_avatars = false
          if section.settings.avatar_1 != blank or section.settings.avatar_2 != blank or section.settings.avatar_3 != blank or section.settings.avatar_4 != blank or section.settings.avatar_5 != blank
            assign has_avatars = true
          endif
        -%}

        {%- if has_avatars or section.settings.stat_1 != blank or section.settings.stat_2 != blank -%}
          <div class="split-hero__proof">
            {%- if has_avatars -%}
              <div class="split-hero__avatars" aria-hidden="true">
                {%- for i in (1..5) -%}
                  {%- assign avatar_key = 'avatar_' | append: i -%}
                  {%- if section.settings[avatar_key] != blank -%}
                    <div class="split-hero__avatar">
                      {{- section.settings[avatar_key] | image_url: width: 80, format: 'webp' | image_tag: class: 'split-hero__avatar-img', alt: '', width: 40, height: 40, loading: 'lazy' -}}
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}

            <div class="split-hero__stats">
              {%- if section.settings.stat_1 != blank -%}
                <p class="split-hero__stat">{{ section.settings.stat_1 }}</p>
              {%- endif -%}
              {%- if section.settings.stat_2 != blank -%}
                <p class="split-hero__stat">
                  {{- section.settings.stat_2 -}}
                  {%- if section.settings.stat_2_highlight != blank -%}
                    <span class="split-hero__stat-accent"> {{ section.settings.stat_2_highlight }}</span>
                  {%- endif -%}
                </p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Right: Product image {%- endcomment -%}
    <div class="split-hero__media">
      {%- if section.settings.image != blank -%}
        {{- section.settings.image
          | image_url: width: 900, format: 'webp'
          | image_tag:
            class: 'split-hero__image',
            alt: shop.name,
            loading: 'eager'
        -}}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'split-hero__placeholder' }}
      {%- endif -%}
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const typewriterElement = document.getElementById('Typewriter-{{ section.id }}');
  if (!typewriterElement) return;

  const words = typewriterElement.getAttribute('data-words').split(',').map(w => w.trim());
  let wordIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  let typeSpeed = 150;

  function type() {
    const currentWord = words[wordIndex];
    
    if (isDeleting) {
      typewriterElement.textContent = currentWord.substring(0, charIndex - 1);
      charIndex--;
      typeSpeed = 75; // मिटाने की स्पीड तेज रखी है
    } else {
      typewriterElement.textContent = currentWord.substring(0, charIndex + 1);
      charIndex++;
      typeSpeed = 150; // टाइपिंग की स्पीड
    }

    if (!isDeleting && charIndex === currentWord.length) {
      isDeleting = true;
      typeSpeed = 2000; // शब्द पूरा होने के बाद 2 सेकंड का ठहराव
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      wordIndex = (wordIndex + 1) % words.length;
      typeSpeed = 500;
    }

    setTimeout(type, typeSpeed);
  }

  if (words.length > 0 && words[0] !== "") {
    type();
  }
});
</script>

{% stylesheet %}
  .split-hero {
    padding: 5rem 0;
    background: var(--color-background);
    overflow: hidden;
  }

  .split-hero__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
    display: flex;
    align-items: center;
    gap: 4.5rem;
  }

  .split-hero__inner--flip { flex-direction: row-reverse; }

  .split-hero__content {
    flex: 1;
    min-width: 0;
    animation: split-hero-rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .split-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--split-accent, #c49a5e);
    margin: 0 0 1.125rem;
  }

  .split-hero__eyebrow::before {
    content: '';
    width: 28px;
    height: 2px;
    background: var(--split-accent, #c49a5e);
  }

  .split-hero__heading {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
    margin: 0 0 1.5rem;
  }

  .split-hero__heading-block {
    display: block; /* "Beyond Furniture" को अलग लाइन में रखने के लिए */
  }

  .split-hero__typewriter-container {
    color: var(--split-accent, #c49a5e);
    display: inline-block;
  }

  .split-hero__cursor {
    display: inline-block;
    margin-left: 2px;
    font-weight: 300;
    animation: blink 0.8s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .split-hero__description {
    font-size: 1rem;
    line-height: 1.7;
    opacity: 0.62;
    margin: 0 0 2.5rem;
    max-width: 48ch;
  }

  .split-hero__bottom {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .split-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 1.875rem;
    background: var(--color-foreground);
    color: var(--color-background);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .split-hero__cta:hover {
    background: var(--split-accent, #c49a5e);
    color: #fff;
    transform: translateY(-3px);
    box-shadow: 0 12px 24px color-mix(in srgb, var(--split-accent, #c49a5e) 45%, transparent);
  }

  .split-hero__proof { display: flex; align-items: center; gap: 0.875rem; }
  .split-hero__avatars { display: flex; align-items: center; }
  .split-hero__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    border: 2.5px solid var(--color-background);
    margin-left: -12px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
  }
  .split-hero__avatar:first-child { margin-left: 0; }
  .split-hero__stat { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; margin: 0; opacity: 0.75; }
  .split-hero__stat-accent { color: var(--split-accent, #c49a5e); opacity: 1; }

  .split-hero__media {
    position: relative;
    flex: 0 0 48%;
    max-width: 48%;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 24px 24px 0 -4px color-mix(in srgb, var(--split-accent, #c49a5e) 28%, transparent), 0 26px 55px rgba(0, 0, 0, 0.14);
    animation: split-hero-rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }

  .split-hero__image { width: 100%; height: auto; display: block; transition: transform 0.6s ease; }
  .split-hero__media:hover .split-hero__image { transform: scale(1.06); }

  @keyframes split-hero-rise {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 767px) {
    .split-hero__inner, .split-hero__inner--flip { flex-direction: column-reverse; gap: 2.25rem; }
    .split-hero__content, .split-hero__media { max-width: 100%; width: 100%; }
    .split-hero__heading { text-align: center; }
    .split-hero__bottom { justify-content: center; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Split Hero Typewriter",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Why choose us"
    },
    {
      "type": "text",
      "id": "heading_static",
      "label": "Static Heading",
      "default": "Beyond Furniture"
    },
    {
      "type": "text",
      "id": "typewriter_words",
      "label": "Typewriter Words (Comma separated)",
      "default": "Creating Lifestyle, Modern Design, Quality Comfort",
      "info": "Separate each phrase with a comma"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "With thousands of satisfied customers, we are a trusted name in quality furniture."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button Label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Social Proof"
    },
    { "type": "image_picker", "id": "avatar_1", "label": "Avatar 1" },
    { "type": "image_picker", "id": "avatar_2", "label": "Avatar 2" },
    { "type": "image_picker", "id": "avatar_3", "label": "Avatar 3" },
    { "type": "image_picker", "id": "avatar_4", "label": "Avatar 4" },
    { "type": "image_picker", "id": "avatar_5", "label": "Avatar 5" },
    { "type": "text", "id": "stat_1", "label": "Stat Line 1", "default": "Trusted by thousands" },
    { "type": "text", "id": "stat_2", "label": "Stat Line 2", "default": "Loved by" },
    { "type": "text", "id": "stat_2_highlight", "label": "Stat Highlight", "default": "Homes" },
    {
      "type": "header",
      "content": "Media & Layout"
    },
    { "type": "image_picker", "id": "image", "label": "Main Image" },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#c49a5e"
    }
  ],
  "presets": [
    {
      "name": "Split Hero Typewriter"
    }
  ]
}
{% endschema %}