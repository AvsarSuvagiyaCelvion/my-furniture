{%- if section.settings.sticky_header -%}
  <style>
    :root {
      --header-height: 80px;
    }
    body {
      padding-top: var(--header-height);
    }
  </style>
{%- endif -%}

<header
  class="header{% if section.settings.sticky_header %} header--sticky{% endif %}"
  id="shopify-section-header"
  style="--header-accent: {{ section.settings.accent_color }};"
>
  <div class="header__inner">
    {%- comment -%} Logo {%- endcomment -%}
    <div class="header__logo">
      {%- if section.settings.logo != blank -%}
        <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
          {{-
            section.settings.logo
            | image_url: width: section.settings.logo_max_width, format: 'webp'
            | image_tag:
              class: 'header__logo-img',
              alt: shop.name,
              width: section.settings.logo_max_width,
              loading: 'eager'
          -}}
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="header__logo-link header__logo-wordmark">
          {{- shop.name -}}
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Desktop Navigation {%- endcomment -%}
    <nav class="header__nav" aria-label="{{ 'header.navigation' | t }}">
      <ul class="header__nav-list" role="list">
        {%- for link in section.settings.menu.links -%}
          <li class="header__nav-item{% if link.links.size > 0 %} has-dropdown{% endif %}">
            <a
              href="{{ link.url }}"
              class="header__nav-link{% if link.active %} is-active{% endif %}"
            >
              <span>{{- link.title -}}</span>
              {%- if link.links.size > 0 -%}
                <svg class="header__chevron" width="8" height="5" viewBox="0 0 10 6" fill="none">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <div class="header__dropdown-wrapper">
                <ul class="header__dropdown" role="list">
                  {%- for child in link.links -%}
                    <li>
                      <a href="{{ child.url }}" class="header__dropdown-link{% if child.active %} is-active{% endif %}">
                        {{- child.title -}}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} Header Actions {%- endcomment -%}
    <div class="header__actions">
      {%- if section.settings.show_search -%}
        <button type="button" class="header__action-btn" aria-label="Search" id="search-open">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header__action-btn" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="header__action-btn header__cart-btn">
        <div class="header__cart-wrap">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="header__cart-badge">{{ cart.item_count }}</span>
          {%- endif -%}
        </div>
      </a>

      <button type="button" class="header__burger-btn header__action-btn" aria-label="Menu">
        <div class="header__burger"><span></span><span></span></div>
      </button>
    </div>
  </div>

  {%- comment -%} Refined Search Panel {%- endcomment -%}
  <div class="header__search-panel" id="header-search">
    <div class="header__search-inner">
      <form action="{{ routes.search_url }}" method="get" class="header__search-form">
        <input type="search" name="q" placeholder="What are you looking for?" class="header__search-input">
        <button type="submit" class="header__search-submit">Search</button>
      </form>
      <button type="button" class="header__search-close">✕</button>
    </div>
  </div>
</header>

{%- comment -%} Modern Mobile Drawer {%- endcomment -%}
<div class="mobile-nav" id="mobile-nav">
  <div class="mobile-nav__overlay"></div>
  <div class="mobile-nav__drawer">
    <div class="mobile-nav__header">
      <span class="mobile-nav__brand">{{ shop.name }}</span>
      <button type="button" class="mobile-nav__close">✕</button>
    </div>
    <ul class="mobile-nav__list">
      {%- for link in section.settings.menu.links -%}
        <li class="mobile-nav__item">
          <a href="{{ link.url }}" class="mobile-nav__link{% if link.active %} is-active{% endif %}">{{ link.title }}</a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{% stylesheet %}
  :root {
    --header-height: 80px;
    --header-height-scrolled: 64px;
    --transition-main: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  /* --- Active Page Styling --- */

  /* Desktop: Active link ka text color aur underline hamesha dikhegi */
  .header__nav-link.is-active {
    color: var(--header-accent) !important;
  }

  .header__nav-link.is-active span::after {
    width: 100% !important;
  }

  /* Dropdown: Agar dropdown ka koi item active hai */
  .header__dropdown-link.is-active {
    color: var(--header-accent) !important;
    background: #f9f9f9;
    font-weight: 700;
  }

  /* Mobile: Mobile menu mein active link ko highlight karein */
  .mobile-nav__link.is-active {
    color: var(--header-accent) !important;
    border-left: 4px solid var(--header-accent);
    padding-left: 15px !important;
    background: rgba(var(--header-accent), 0.05);
  }

  .header {
    background: #ffffff;
    border-bottom: 1px solid #f0f0f0;
    z-index: 1000;
    width: 100%;
    transition: var(--transition-main);
  }
  .header__logo-img {
    display: block;
    width: 200px !important; 
    height: 100px !important; 
    object-fit: contain; 
  }

  .header--sticky {
    position: fixed;
    top: 0;
    left: 0;
  }

  /* Shrink & Glass effect on scroll */
  .header--scrolled {
    height: var(--header-height-scrolled);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
  }

  .header__inner {
    max-width: 1400px;
    margin: 0 auto;
    height: 100%;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: var(--transition-main);
  }

  .header--scrolled .header__inner {
    height: var(--header-height-scrolled);
  }

  /* Logo Styling */
  .header__logo-wordmark {
    font-size: 1.25rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #121212;
    text-decoration: none;
  }

  /* Professional Navigation */
  .header__nav {
    height: 100%;
    display: none;
  }

  @media (min-width: 1024px) {
    .header__nav {
      display: flex;
    }
  }

  .header__nav-list {
    display: flex;
    list-style: none;
    height: 100%;
    margin: 0;
    padding: 0;
  }

  .header__nav-item {
    height: 100%;
    display: flex;
    align-items: center;
    position: relative;
  }

  .header__nav-link {
    padding: 0 20px;
    text-decoration: none;
    color: #121212;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s ease;
  }

  .header__nav-link span {
    position: relative;
  }

  /* Elegant Underline Hover */
  .header__nav-link span::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--header-accent);
    transition: width 0.3s ease;
  }

  .header__nav-link:hover span::after {
    width: 100%;
  }

  /* Dropdown Professional Look */
  .header__dropdown-wrapper {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    opacity: 0;
    visibility: hidden;
    transition: var(--transition-main);
    padding-top: 10px;
  }

  .header__nav-item:hover .header__dropdown-wrapper {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .header__dropdown {
    background: #fff;
    min-width: 220px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    border: 1px solid #f0f0f0;
    border-radius: 4px;
    list-style: none;
    padding: 15px 0;
  }

  .header__dropdown-link {
    display: block;
    padding: 10px 25px;
    text-decoration: none;
    color: #444;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .header__dropdown-link:hover {
    background: #f9f9f9;
    color: var(--header-accent);
    padding-left: 30px;
  }

  /* Action Buttons */
  .header__actions {
    display: flex;
    gap: 10px;
  }

  .header__action-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #121212;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: 50%;
    transition: var(--transition-main);
  }

  .header__action-btn:hover {
    background: #f5f5f5;
    color: var(--header-accent);
  }

  /* Cart Badge */
  .header__cart-wrap {
    position: relative;
  }
  .header__cart-badge {
    position: absolute;
    top: -8px;
    right: -8px;
    background: #121212;
    color: #fff;
    font-size: 10px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }

  /* Minimal Burger */
  .header__burger {
    width: 20px;
    height: 12px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .header__burger span {
    width: 100%;
    height: 1.5px;
    background: currentColor;
    transition: 0.3s;
  }

  @media (min-width: 1024px) {
    .header__burger-btn {
      display: none;
    }
  }

  /* Search Panel Layer */
  .header__search-panel {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: #fff;
    padding: 20px 0;
    transform: translateY(-100%);
    transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .header__search-panel.is-open {
    transform: translateY(0);
  }

  .header__search-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    padding: 0 20px;
  }

  .header__search-form {
    flex: 1;
    display: flex;
    border-bottom: 2px solid #121212;
  }

  .header__search-input {
    border: none;
    padding: 15px 0;
    width: 100%;
    font-size: 1.2rem;
    outline: none;
  }

  .header__search-submit {
    background: none;
    border: none;
    text-transform: uppercase;
    font-weight: 700;
    cursor: pointer;
  }

  /* Mobile Drawer */
  .mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 2000;
    visibility: hidden;
  }

  .mobile-nav.is-open {
    visibility: visible;
  }

  .mobile-nav__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: 0.3s;
  }

  .mobile-nav.is-open .mobile-nav__overlay {
    opacity: 1;
  }

  .mobile-nav__drawer {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 300px;
    background: #fff;
    transform: translateX(-100%);
    transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    padding: 30px;
  }

  .mobile-nav.is-open .mobile-nav__drawer {
    transform: translateX(0);
  }

  .mobile-nav__header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 40px;
  }

  .mobile-nav__list {
    list-style: none;
    padding: 0;
  }

  .mobile-nav__link {
    display: block;
    padding: 15px 0;
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    color: #121212;
    border-bottom: 1px solid #f0f0f0;
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', function () {
    const header = document.getElementById('shopify-section-header');
    const burgerBtn = document.querySelector('.header__burger-btn');
    const mobileNav = document.getElementById('mobile-nav');
    const mobileClose = document.querySelector('.mobile-nav__close');
    const searchOpen = document.getElementById('search-open');
    const searchPanel = document.getElementById('header-search');
    const searchClose = document.querySelector('.header__search-close');

    // Scroll Logic
    window.addEventListener(
      'scroll',
      () => {
        if (window.scrollY > 50) {
          header.classList.add('header--scrolled');
        } else {
          header.classList.remove('header--scrolled');
        }
      },
      { passive: true }
    );

    // Menu Logic
    burgerBtn.addEventListener('click', () => mobileNav.classList.add('is-open'));
    mobileClose.addEventListener('click', () => mobileNav.classList.remove('is-open'));

    // Search Logic
    searchOpen.addEventListener('click', () => searchPanel.classList.add('is-open'));
    searchClose.addEventListener('click', () => searchPanel.classList.remove('is-open'));
  });
{% endjavascript %}

{% schema %}
{
  "name": "Professional Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "label": "Logo Width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Enable Sticky Header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show Search",
      "default": true
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#c49a5e"
    }
  ]
}
{% endschema %}
