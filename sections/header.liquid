{%- if section.settings.sticky_header -%}
  <style>
    body { padding-top: 72px; }
  </style>
{%- endif -%}

<header
  class="header{% if section.settings.sticky_header %} header--sticky{% endif %}"
  id="shopify-section-header"
  style="--header-accent: {{ section.settings.accent_color }};"
>
  <div class="header__inner">
    {%- comment -%} Logo {%- endcomment -%}
    <div class="header__logo">
      {%- if section.settings.logo != blank -%}
        <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
          {{-
            section.settings.logo
            | image_url: width: section.settings.logo_max_width, format: 'webp'
            | image_tag:
              class: 'header__logo-img',
              alt: shop.name,
              width: section.settings.logo_max_width,
              loading: 'eager'
          -}}
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="header__logo-link header__logo-wordmark">
          {{- shop.name -}}
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Desktop Navigation {%- endcomment -%}
    <nav class="header__nav" aria-label="{{ 'header.navigation' | t }}">
      <ul class="header__nav-list" role="list">
        {%- for link in section.settings.menu.links -%}
          <li class="header__nav-item{% if link.links.size > 0 %} has-dropdown{% endif %}">
            <a
              href="{{ link.url }}"
              class="header__nav-link{% if link.active %} is-active{% endif %}"
              {% if link.links.size > 0 %}
                aria-haspopup="true" aria-expanded="false"
              {% endif %}
            >
              {{- link.title -}}
              {%- if link.links.size > 0 -%}
                <svg class="header__chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <ul class="header__dropdown" role="list">
                {%- for child in link.links -%}
                  <li>
                    <a
                      href="{{ child.url }}"
                      class="header__dropdown-link{% if child.active %} is-active{% endif %}"
                    >
                      {{- child.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} Header Actions {%- endcomment -%}
    <div class="header__actions">
      {%- if section.settings.show_search -%}
        <button
          type="button"
          class="header__action-btn header__search-btn"
          aria-label="{{ 'header.search' | t }}"
          aria-expanded="false"
          aria-controls="header-search"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="8.5" cy="8.5" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M14 14l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <shopify-account
          menu="{{ section.settings.customer_account_menu }}"
          class="header__action-btn"
          aria-label="{{ 'header.account' | t }}"
        >
          {{- 'icon-account.svg' | inline_asset_content -}}
        </shopify-account>
      {%- endif -%}

      <a
        href="{{ routes.cart_url }}"
        class="header__action-btn header__cart-btn"
        aria-label="{{ 'header.cart' | t }}"
      >
        <span class="header__cart-wrap">
          {{- 'icon-cart.svg' | inline_asset_content -}}
          {%- if cart.item_count > 0 -%}
            <span class="header__cart-badge" aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
        </span>
      </a>

      <button
        type="button"
        class="header__action-btn header__burger-btn"
        aria-label="{{ 'header.menu' | t }}"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="header__burger" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>
    </div>
  </div>

  {%- comment -%} Search Panel {%- endcomment -%}
  {%- if section.settings.show_search -%}
    <div class="header__search-panel" id="header-search" aria-hidden="true">
      <div class="header__search-inner">
        <form action="{{ routes.search_url }}" method="get" role="search" class="header__search-form">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true" class="header__search-icon">
            <circle cx="8.5" cy="8.5" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M14 14l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <input
            type="search"
            name="q"
            class="header__search-input"
            placeholder="{{ 'search.placeholder' | t }}"
            aria-label="{{ 'search.title' | t }}"
            autocomplete="off"
          >
          <button type="submit" class="header__search-submit" aria-label="{{ 'search.submit' | t }}">
            {{ 'search.submit' | t }}
          </button>
        </form>
        <button type="button" class="header__search-close" aria-label="{{ 'header.close' | t }}">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M14 4L4 14M4 4l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>
  {%- endif -%}
</header>

{%- comment -%} Mobile Navigation Drawer {%- endcomment -%}
<div
  class="mobile-nav"
  id="mobile-nav"
  aria-hidden="true"
  style="--header-accent: {{ section.settings.accent_color }};"
>
  <div class="mobile-nav__drawer">
    <div class="mobile-nav__header">
      <a href="{{ routes.root_url }}" class="mobile-nav__brand">{{ shop.name }}</a>
      <button type="button" class="mobile-nav__close" aria-label="{{ 'header.close' | t }}">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M15 5L5 15M5 5l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <nav aria-label="{{ 'header.navigation' | t }}">
      <ul class="mobile-nav__list" role="list">
        {%- for link in section.settings.menu.links -%}
          <li class="mobile-nav__item">
            <div class="mobile-nav__row">
              <a href="{{ link.url }}" class="mobile-nav__link{% if link.active %} is-active{% endif %}">
                {{- link.title -}}
              </a>
              {%- if link.links.size > 0 -%}
                <button
                  type="button"
                  class="mobile-nav__expand"
                  aria-expanded="false"
                  aria-label="{{ link.title }}"
                >
                  <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                    <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              {%- endif -%}
            </div>
            {%- if link.links.size > 0 -%}
              <ul class="mobile-nav__submenu" role="list" hidden>
                {%- for child in link.links -%}
                  <li>
                    <a
                      href="{{ child.url }}"
                      class="mobile-nav__submenu-link{% if child.active %} is-active{% endif %}"
                    >
                      {{- child.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- if shop.customer_accounts_enabled -%}
      <div class="mobile-nav__footer">
        <shopify-account menu="{{ section.settings.customer_account_menu }}" class="mobile-nav__account">
          {{- 'icon-account.svg' | inline_asset_content -}}
          <span>{{ 'header.account' | t }}</span>
        </shopify-account>
      </div>
    {%- endif -%}
  </div>
  <div class="mobile-nav__overlay" aria-hidden="true"></div>
</div>

{% stylesheet %}
  /* ── Reset & Base ──────────────────────────────────── */
  .header,
  .mobile-nav {
    box-sizing: border-box;
  }

  /* ── Header ────────────────────────────────────────── */
  .header {
    background-color: var(--color-background);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    position: relative;
    z-index: 100;
    transition: box-shadow 0.3s ease, background-color 0.3s ease;
  }

  .header--sticky {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
  }

  .header--scrolled {
    box-shadow: 0 4px 22px rgba(0, 0, 0, 0.1);
    backdrop-filter: saturate(1.4);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
    gap: 1.5rem;
  }

  /* ── Logo ──────────────────────────────────────────── */
  .header__logo {
    flex-shrink: 0;
  }

  .header__logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-foreground);
    transition: opacity 0.2s ease;
  }

  .header__logo-link:hover {
    opacity: 0.85;
  }

  .header__logo-img {
    display: block;
    height: auto;
    max-height: 44px;
    width: auto;
  }

  .header__logo-wordmark {
    font-family: var(--font-primary--family);
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-foreground);
    transition: color 0.2s ease;
  }

  .header__logo-wordmark:hover {
    color: var(--header-accent, #c49a5e);
  }

  /* ── Desktop Navigation ────────────────────────────── */
  .header__nav {
    display: none;
    flex: 1;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .header__nav {
      display: flex;
    }
  }

  .header__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
  }

  .header__nav-item {
    position: relative;
  }

  .header__nav-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.6rem 0.875rem;
    font-family: var(--font-primary--family);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--color-foreground);
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  /* Animated underline */
  .header__nav-link::after {
    content: '';
    position: absolute;
    left: 0.875rem;
    right: 0.875rem;
    bottom: 0.35rem;
    height: 2px;
    background: var(--header-accent, #c49a5e);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .header__nav-link:hover,
  .header__nav-link.is-active {
    color: var(--header-accent, #c49a5e);
  }

  .header__nav-link:hover::after,
  .header__nav-link.is-active::after {
    transform: scaleX(1);
  }

  .header__chevron {
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  .header__nav-item.has-dropdown:hover .header__chevron,
  .header__nav-item.has-dropdown:focus-within .header__chevron {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .header__dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    min-width: 200px;
    background: var(--color-background);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 10px;
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.13);
    list-style: none;
    margin: 0;
    padding: 0.4rem 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.22, 1, 0.36, 1), visibility 0.2s;
    pointer-events: none;
  }

  .header__nav-item.has-dropdown:hover .header__dropdown,
  .header__nav-item.has-dropdown:focus-within .header__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .header__dropdown-link {
    position: relative;
    display: block;
    padding: 0.55rem 1.125rem;
    font-size: 0.875rem;
    font-family: var(--font-primary--family);
    text-decoration: none;
    color: var(--color-foreground);
    white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease, padding-left 0.15s ease;
  }

  /* Accent indicator bar on dropdown items */
  .header__dropdown-link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 0;
    background: var(--header-accent, #c49a5e);
    border-radius: 0 2px 2px 0;
    transition: height 0.2s ease;
  }

  .header__dropdown-link:hover,
  .header__dropdown-link.is-active {
    background: color-mix(in srgb, var(--header-accent, #c49a5e) 9%, transparent);
    color: var(--header-accent, #c49a5e);
    padding-left: 1.375rem;
  }

  .header__dropdown-link:hover::before,
  .header__dropdown-link.is-active::before {
    height: 58%;
  }

  /* ── Header Actions ────────────────────────────────── */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    flex-shrink: 0;
  }

  .header__action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    background: none;
    color: var(--color-foreground);
    cursor: pointer;
    border-radius: 50%;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
    padding: 0;
    flex-shrink: 0;
  }

  .header__action-btn:hover {
    background: color-mix(in srgb, var(--header-accent, #c49a5e) 13%, transparent);
    color: var(--header-accent, #c49a5e);
    transform: translateY(-1px);
  }

  .header__action-btn svg {
    display: block;
    width: 20px;
    height: 20px;
  }

  /* Cart badge */
  .header__cart-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  .header__cart-badge {
    position: absolute;
    top: -7px;
    right: -9px;
    min-width: 17px;
    height: 17px;
    background: var(--header-accent, #c49a5e);
    color: #fff;
    border-radius: 50%;
    font-size: 0.625rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    line-height: 1;
    font-family: var(--font-primary--family);
    box-shadow: 0 2px 6px color-mix(in srgb, var(--header-accent, #c49a5e) 50%, transparent);
  }

  /* Hamburger button */
  .header__burger-btn {
    display: flex;
  }

  @media (min-width: 768px) {
    .header__burger-btn {
      display: none;
    }
  }

  .header__burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 20px;
    height: 16px;
  }

  .header__burger span {
    display: block;
    height: 1.5px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: center;
  }

  .header__burger-btn[aria-expanded='true'] .header__burger span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .header__burger-btn[aria-expanded='true'] .header__burger span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .header__burger-btn[aria-expanded='true'] .header__burger span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ── Search Panel ──────────────────────────────────── */
  .header__search-panel {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-background);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    box-shadow: 0 12px 26px rgba(0, 0, 0, 0.08);
    padding: 0.875rem 0;
    transform: translateY(-8px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.22s ease, transform 0.22s cubic-bezier(0.22, 1, 0.36, 1), visibility 0.22s;
    z-index: 10;
  }

  .header__search-panel.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .header__search-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  .header__search-form {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    border: 1.5px solid rgba(0, 0, 0, 0.16);
    border-radius: 999px;
    padding: 0 0.4rem 0 1rem;
    background: var(--color-background);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .header__search-form:focus-within {
    border-color: var(--header-accent, #c49a5e);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--header-accent, #c49a5e) 14%, transparent);
  }

  .header__search-icon {
    flex-shrink: 0;
    opacity: 0.4;
  }

  .header__search-input {
    flex: 1;
    border: none;
    background: none;
    padding: 0.7rem 0;
    font-family: var(--font-primary--family);
    font-size: 0.9375rem;
    color: var(--color-foreground);
    outline: none;
    min-width: 0;
  }

  .header__search-input::placeholder {
    color: rgba(0, 0, 0, 0.35);
  }

  .header__search-submit {
    flex-shrink: 0;
    background: var(--header-accent, #c49a5e);
    color: #fff;
    border: none;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    font-family: var(--font-primary--family);
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
  }

  .header__search-submit:hover {
    transform: translateY(-1px);
    filter: brightness(1.07);
    box-shadow: 0 6px 16px color-mix(in srgb, var(--header-accent, #c49a5e) 45%, transparent);
  }

  .header__search-close {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    color: var(--color-foreground);
    cursor: pointer;
    border-radius: 50%;
    transition: background 0.15s ease, color 0.15s ease;
    padding: 0;
  }

  .header__search-close:hover {
    background: color-mix(in srgb, var(--header-accent, #c49a5e) 13%, transparent);
    color: var(--header-accent, #c49a5e);
  }

  /* ── Mobile Navigation Drawer ──────────────────────── */
  .mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 200;
    visibility: hidden;
  }

  @media (min-width: 768px) {
    .mobile-nav {
      display: none;
    }
  }

  .mobile-nav.is-open {
    visibility: visible;
  }

  .mobile-nav__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mobile-nav.is-open .mobile-nav__overlay {
    opacity: 1;
  }

  .mobile-nav__drawer {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(320px, 85vw);
    background: var(--color-background);
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    overflow-y: auto;
    overscroll-behavior: contain;
    z-index: 1;
  }

  .mobile-nav.is-open .mobile-nav__drawer {
    transform: translateX(0);
  }

  .mobile-nav__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.125rem 1.25rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    flex-shrink: 0;
  }

  .mobile-nav__brand {
    font-family: var(--font-primary--family);
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-foreground);
  }

  .mobile-nav__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    background: none;
    color: var(--color-foreground);
    cursor: pointer;
    border-radius: 50%;
    transition: background 0.15s ease, color 0.15s ease;
    padding: 0;
    flex-shrink: 0;
  }

  .mobile-nav__close:hover {
    background: color-mix(in srgb, var(--header-accent, #c49a5e) 13%, transparent);
    color: var(--header-accent, #c49a5e);
  }

  .mobile-nav__list {
    list-style: none;
    margin: 0;
    padding: 0.375rem 0;
    flex: 1;
  }

  .mobile-nav__item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .mobile-nav__row {
    display: flex;
    align-items: center;
  }

  .mobile-nav__link {
    position: relative;
    flex: 1;
    display: block;
    padding: 0.875rem 1.25rem;
    font-family: var(--font-primary--family);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-foreground);
    transition: color 0.18s ease, padding-left 0.18s ease;
  }

  /* Accent bar on active/hover mobile link */
  .mobile-nav__link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7rem;
    bottom: 0.7rem;
    width: 3px;
    background: var(--header-accent, #c49a5e);
    border-radius: 0 2px 2px 0;
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.2s ease;
  }

  .mobile-nav__link:hover,
  .mobile-nav__link.is-active {
    color: var(--header-accent, #c49a5e);
    padding-left: 1.45rem;
  }

  .mobile-nav__link:hover::before,
  .mobile-nav__link.is-active::before {
    transform: scaleY(1);
  }

  .mobile-nav__expand {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 50px;
    border: none;
    background: none;
    color: var(--color-foreground);
    cursor: pointer;
    padding: 0;
  }

  .mobile-nav__expand svg {
    transition: transform 0.25s ease;
  }

  .mobile-nav__expand[aria-expanded='true'] svg {
    transform: rotate(180deg);
    color: var(--header-accent, #c49a5e);
  }

  .mobile-nav__submenu {
    list-style: none;
    margin: 0;
    padding: 0.25rem 0 0.5rem;
    background: color-mix(in srgb, var(--header-accent, #c49a5e) 5%, transparent);
  }

  .mobile-nav__submenu-link {
    display: block;
    padding: 0.5625rem 1.25rem 0.5625rem 1.875rem;
    font-family: var(--font-primary--family);
    font-size: 0.9375rem;
    text-decoration: none;
    color: var(--color-foreground);
    opacity: 0.75;
    transition: opacity 0.15s ease, color 0.15s ease;
  }

  .mobile-nav__submenu-link:hover,
  .mobile-nav__submenu-link.is-active {
    opacity: 1;
    color: var(--header-accent, #c49a5e);
  }

  .mobile-nav__footer {
    padding: 1rem 1.25rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    flex-shrink: 0;
  }

  .mobile-nav__account {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-primary--family);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-foreground);
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    transition: color 0.15s ease;
  }

  .mobile-nav__account:hover {
    color: var(--header-accent, #c49a5e);
  }

  .mobile-nav__account svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var header = document.getElementById('shopify-section-header');
    var mobileNav = document.getElementById('mobile-nav');
    var burgerBtn = header && header.querySelector('.header__burger-btn');
    var mobileClose = mobileNav && mobileNav.querySelector('.mobile-nav__close');
    var mobileOverlay = mobileNav && mobileNav.querySelector('.mobile-nav__overlay');
    var searchBtn = header && header.querySelector('.header__search-btn');
    var searchPanel = document.getElementById('header-search');
    var searchClose = searchPanel && searchPanel.querySelector('.header__search-close');
    var searchInput = searchPanel && searchPanel.querySelector('.header__search-input');

    // Sticky scroll shadow
    if (header && header.classList.contains('header--sticky')) {
      var onScroll = function () {
        header.classList.toggle('header--scrolled', window.scrollY > 8);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    // Mobile menu helpers
    function openMobileMenu() {
      if (!mobileNav || !burgerBtn) return;
      mobileNav.classList.add('is-open');
      mobileNav.setAttribute('aria-hidden', 'false');
      burgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMobileMenu() {
      if (!mobileNav || !burgerBtn) return;
      mobileNav.classList.remove('is-open');
      mobileNav.setAttribute('aria-hidden', 'true');
      burgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    if (burgerBtn) burgerBtn.addEventListener('click', openMobileMenu);
    if (mobileClose) mobileClose.addEventListener('click', closeMobileMenu);
    if (mobileOverlay) mobileOverlay.addEventListener('click', closeMobileMenu);

    // Mobile submenu expand/collapse
    if (mobileNav) {
      mobileNav.querySelectorAll('.mobile-nav__expand').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var expanded = btn.getAttribute('aria-expanded') === 'true';
          var submenu = btn.closest('.mobile-nav__item').querySelector('.mobile-nav__submenu');
          btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
          if (submenu) submenu.hidden = expanded;
        });
      });
    }

    // Search panel helpers
    function openSearch() {
      if (!searchPanel || !searchBtn) return;
      searchPanel.classList.add('is-open');
      searchPanel.setAttribute('aria-hidden', 'false');
      searchBtn.setAttribute('aria-expanded', 'true');
      if (searchInput)
        setTimeout(function () {
          searchInput.focus();
        }, 200);
    }

    function closeSearch() {
      if (!searchPanel || !searchBtn) return;
      searchPanel.classList.remove('is-open');
      searchPanel.setAttribute('aria-hidden', 'true');
      searchBtn.setAttribute('aria-expanded', 'false');
    }

    if (searchBtn) searchBtn.addEventListener('click', openSearch);
    if (searchClose) searchClose.addEventListener('click', closeSearch);

    // Close on Escape key
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        closeMobileMenu();
        closeSearch();
      }
    });
  })();
{% endjavascript %}

