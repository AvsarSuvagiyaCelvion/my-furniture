<section class="why-us why-us--{{ section.settings.section_background }}">
  <div class="why-us__inner">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="why-us__header why-us__animate">
        {%- if section.settings.heading != blank -%}
          <h2 class="why-us__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="why-us__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div
      class="why-us__grid"
      style="--icon-color: {{ section.settings.icon_color }};"
    >
      {%- for block in section.blocks -%}
        <div
          class="why-us__feature why-us__animate"
          style="--stagger: {{ forloop.index0 | times: 110 }}ms;"
          {{ block.shopify_attributes }}
        >
          <div class="why-us__icon-wrap why-us__icon-wrap--{{ section.settings.icon_style }}">
            <div class="why-us__icon-ring"></div>
            {%- case block.settings.icon -%}
              {%- when 'star' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
              {%- when 'truck' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <rect x="1" y="3" width="15" height="13" rx="1" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M16 8h4l3 3v5h-7V8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <circle cx="5.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="18.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              {%- when 'refresh' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M1 4v6h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M23 20v-6h-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4-4.64 4.36A9 9 0 0 1 3.51 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- when 'shield' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- when 'sparkle' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M12 3c-.5 2.5-3 4.5-5 5 2 .5 4.5 2.5 5 5 .5-2.5 3-4.5 5-5-2-.5-4.5-2.5-5-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <path d="M5 3c-.25 1-1.25 2-2 2 .75.25 1.75 1 2 2 .25-1 1.25-2 2-2-.75-.25-1.75-1-2-2zM19 15c-.25 1-1.25 2-2 2 .75.25 1.75 1 2 2 .25-1 1.25-2 2-2-.75-.25-1.75-1-2-2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
              {%- when 'heart' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
              {%- when 'clock' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- when 'leaf' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M17 8C8 10 5.9 16.17 3.82 19.27A2 2 0 0 0 5.82 22C8 22 10 20.5 12 19c2-1.5 4.5-3 7-3 0-6-3-8-2-8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <path d="M2 22s4-4 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              {%- when 'gift' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <rect x="2" y="7" width="20" height="14" rx="1" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M16 21V7M8 21V7M2 12h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M12 7C12 7 9 3 7 4s-1.5 3 5 3zM12 7c0 0 3-4 5-3s1.5 3-5 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
              {%- when 'check' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M8 12l3 3 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- when 'diamond' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M6 3h12l4 6-10 12L2 9l4-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <path d="M2 9h20M12 3L8 9l4 12 4-12-4-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
            {%- endcase -%}
          </div>

          <div class="why-us__feature-text">
            {%- if block.settings.title != blank -%}
              <p class="why-us__feature-title">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="why-us__feature-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>

          <div class="why-us__card-shine"></div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% stylesheet %}
  /* ─────────────────────────────────────────────────────
     Keyframes
  ───────────────────────────────────────────────────── */
  @keyframes why-us-float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-6px); }
  }

  @keyframes why-us-pulse-ring {
    0%   { transform: scale(1);    opacity: 0.6; }
    100% { transform: scale(1.55); opacity: 0; }
  }

  @keyframes why-us-underline {
    from { width: 0; }
    to   { width: 56px; }
  }

  @keyframes why-us-shine {
    0%   { left: -75%; }
    100% { left: 125%; }
  }

  /* ─────────────────────────────────────────────────────
     Section shell
  ───────────────────────────────────────────────────── */
  .why-us {
    padding: 5.5rem 0;
    overflow: hidden;
  }

  .why-us--white { background: var(--color-background); }
  .why-us--warm  { background: #faf8f5; }
  .why-us--dark  { background: #18181a; }

  .why-us__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  /* ─────────────────────────────────────────────────────
     Entrance animation base state
  ───────────────────────────────────────────────────── */
  .why-us__animate {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity  0.75s cubic-bezier(0.16, 1, 0.3, 1) var(--stagger, 0ms),
      transform 0.75s cubic-bezier(0.16, 1, 0.3, 1) var(--stagger, 0ms);
  }

  .why-us__animate.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─────────────────────────────────────────────────────
     Section header
  ───────────────────────────────────────────────────── */
  .why-us__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .why-us__heading {
    font-family: var(--font-primary--family);
    font-size: clamp(1.75rem, 3.5vw, 2.625rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--color-foreground);
    margin: 0 0 1rem;
    position: relative;
    display: inline-block;
  }

  /* Animated gold underline */
  .why-us__heading::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    height: 3px;
    width: 0;
    border-radius: 2px;
    background: var(--icon-color, #c49a5e);
  }

  .why-us__header.is-visible .why-us__heading::after {
    animation: why-us-underline 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  .why-us__subheading {
    font-family: var(--font-primary--family);
    font-size: 1rem;
    line-height: 1.65;
    opacity: 0.58;
    margin: 1.25rem auto 0;
    max-width: 52ch;
    color: var(--color-foreground);
  }

  .why-us--dark .why-us__heading { color: #ffffff; }
  .why-us--dark .why-us__subheading { color: rgba(255,255,255,0.55); opacity: 1; }

  /* ─────────────────────────────────────────────────────
     Grid
  ───────────────────────────────────────────────────── */
  .why-us__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 480px) {
    .why-us__grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .why-us__grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 1.25rem;
    }
  }

  /* ─────────────────────────────────────────────────────
     Feature card
  ───────────────────────────────────────────────────── */
  .why-us__feature {
    position: relative;
    overflow: hidden;
    padding: 1.25rem;
    border-radius: 18px;
    border: 1px solid rgba(0, 0, 0, 0.07);
    background: #ffffff;
    display: flex;
    align-items: center;
    gap: 1rem;
    text-align: left;
    cursor: default;

    /* Smooth hover transitions (on top of entrance) */
    transition:
      opacity  0.75s cubic-bezier(0.16, 1, 0.3, 1) var(--stagger, 0ms),
      transform 0.75s cubic-bezier(0.16, 1, 0.3, 1) var(--stagger, 0ms),
      box-shadow   0.35s ease,
      border-color 0.35s ease,
      background   0.35s ease;
  }

  /* Desktop vertical card */
  @media (min-width: 480px) {
    .why-us__feature {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 2.25rem 1.5rem 2rem;
      gap: 0;
    }
  }

  /* Dark variant cards */
  .why-us--dark .why-us__feature {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.08);
  }

  /* Warm variant cards */
  .why-us--warm .why-us__feature {
    background: #ffffff;
  }

  /* ── Hover lift ── */
  @media (min-width: 480px) {
    .why-us__feature.is-visible:hover {
      transform: translateY(-10px);
      box-shadow: 0 28px 70px rgba(0, 0, 0, 0.11);
      border-color: rgba(196, 154, 94, 0.4);
    }

    .why-us--dark .why-us__feature.is-visible:hover {
      background: rgba(255, 255, 255, 0.07);
      border-color: rgba(196, 154, 94, 0.5);
      box-shadow: 0 28px 70px rgba(0, 0, 0, 0.4);
    }
  }

  /* ── Shine sweep on hover ── */
  .why-us__card-shine {
    position: absolute;
    top: 0;
    left: -75%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.55) 50%,
      transparent 60%
    );
    pointer-events: none;
    opacity: 0;
  }

  .why-us__feature.is-visible:hover .why-us__card-shine {
    opacity: 1;
    animation: why-us-shine 0.55s ease forwards;
  }

  /* ─────────────────────────────────────────────────────
     Icon wrapper
  ───────────────────────────────────────────────────── */
  .why-us__icon-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--icon-color, #c49a5e);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .why-us__feature.is-visible:hover .why-us__icon-wrap {
    transform: scale(1.15) rotate(-8deg);
  }

  /* Icon floating when card is hovered */
  .why-us__feature.is-visible:hover .why-us__icon-wrap {
    animation: why-us-float 2s ease-in-out infinite;
  }

  /* Circle style */
  .why-us__icon-wrap--circle {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: rgba(196, 154, 94, 0.1);
    margin-bottom: 1.5rem;
  }

  /* Square style */
  .why-us__icon-wrap--square {
    width: 70px;
    height: 70px;
    border-radius: 16px;
    background: rgba(196, 154, 94, 0.1);
    margin-bottom: 1.5rem;
  }

  /* Plain style */
  .why-us__icon-wrap--plain {
    width: 42px;
    height: 42px;
    margin-bottom: 1.25rem;
  }

  /* Mobile: no bottom margin (horizontal layout) */
  @media (max-width: 479px) {
    .why-us__icon-wrap--circle,
    .why-us__icon-wrap--square {
      margin-bottom: 0;
      width: 52px;
      height: 52px;
    }
    .why-us__icon-wrap--plain {
      margin-bottom: 0;
      width: 36px;
      height: 36px;
    }
    .why-us__icon-wrap svg {
      width: 22px !important;
      height: 22px !important;
    }
  }

  /* Dark bg icon wrapper */
  .why-us--dark .why-us__icon-wrap--circle,
  .why-us--dark .why-us__icon-wrap--square {
    background: rgba(196, 154, 94, 0.15);
  }

  /* ── Pulse ring on hover ── */
  .why-us__icon-ring {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 2px solid var(--icon-color, #c49a5e);
    opacity: 0;
    pointer-events: none;
  }

  .why-us__icon-wrap--plain .why-us__icon-ring {
    display: none;
  }

  .why-us__feature.is-visible:hover .why-us__icon-ring {
    animation: why-us-pulse-ring 0.7s cubic-bezier(0.215, 0.61, 0.355, 1) forwards;
  }

  /* ─────────────────────────────────────────────────────
     Feature text
  ───────────────────────────────────────────────────── */
  .why-us__feature-text {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  @media (min-width: 480px) {
    .why-us__feature-text {
      align-items: center;
    }
  }

  .why-us__feature-title {
    font-family: var(--font-primary--family);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin: 0;
    line-height: 1.3;
    transition: color 0.25s ease;
  }

  .why-us__feature.is-visible:hover .why-us__feature-title {
    color: var(--icon-color, #c49a5e);
  }

  .why-us--dark .why-us__feature-title { color: #ffffff; }

  .why-us__feature-desc {
    font-family: var(--font-primary--family);
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-foreground);
    opacity: 0.55;
    margin: 0;
    max-width: 24ch;
  }

  .why-us--dark .why-us__feature-desc {
    color: rgba(255, 255, 255, 0.5);
    opacity: 1;
  }

  /* ─────────────────────────────────────────────────────
     Responsive padding
  ───────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .why-us { padding: 3.5rem 0; }
    .why-us__header { margin-bottom: 2rem; }
  }

  /* ─────────────────────────────────────────────────────
     Respect reduced motion preference
  ───────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .why-us__animate {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .why-us__heading::after {
      animation: none;
      width: 56px;
    }
    .why-us__feature.is-visible:hover .why-us__icon-wrap {
      animation: none;
    }
    .why-us__feature.is-visible:hover .why-us__card-shine {
      animation: none;
      opacity: 0;
    }
    .why-us__feature.is-visible:hover .why-us__icon-ring {
      animation: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var targets = document.querySelectorAll('.why-us__animate');

    if (reducedMotion) {
      targets.forEach(function (el) { el.classList.add('is-visible'); });
      return;
    }

    if (!('IntersectionObserver' in window)) {
      targets.forEach(function (el) { el.classList.add('is-visible'); });
      return;
    }

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;

          var el = entry.target;
          el.classList.add('is-visible');

          /* Reset stagger delay after entrance so hover is instant */
          var delay = parseInt(el.style.getPropertyValue('--stagger') || '0', 10);
          setTimeout(function () {
            el.style.setProperty('--stagger', '0ms');
          }, 750 + delay);

          observer.unobserve(el);
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );

    targets.forEach(function (el) { observer.observe(el); });
  })();
{% endjavascript %}

