<footer class="simple-footer">
  <div class="footer-center-content">
    
    <p class="footer-text">
      &copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All Rights Reserved.
      <span class="footer-separator">|</span>
      
      {% for link in section.settings.policy_menu.links %}
        <a href="{{ link.url }}" class="footer-policy-link">{{ link.title }}</a>
        {% unless forloop.last %}<span class="footer-dot">•</span>{% endunless %}
      {% endfor %}
    </p>

  </div>
</footer>

<style>
  .simple-footer {
    background-color: #000000; /* Pure Black Background */
    color: #ffffff; /* Pure White Text */
    padding: 10px;
    text-align: center; /* Center Alignment */
    border-top: 1px solid #333; /* Halki si line top par */
  }

  .footer-text {
    font-size: 14px;
    letter-spacing: 0.5px;
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    opacity: 0.9;
  }

  .footer-policy-link {
    color: #ffffff;
    text-decoration: none;
    transition: opacity 0.3s, color 0.3s;
    font-weight: 400;
  }

  .footer-policy-link:hover {
    color: {{ section.settings.accent_color | default: '#c49a5e' }}; /* Hover par color change */
    opacity: 1;
  }

  .footer-separator {
    margin: 0 10px;
    opacity: 0.5;
  }

  .footer-dot {
    margin: 0 5px;
    opacity: 0.5;
  }

  /* Mobile Responsive */
  @media (max-width: 600px) {
    .footer-text {
      flex-direction: column; /* Mobile par upar niche aa jayega center mein */
      gap: 12px;
    }
    .footer-separator, .footer-dot {
      display: none; /* Mobile par separator hata denge taaki clean lage */
    }
  }
</style>

{% schema %}
{
  "name": "Simple Center Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "policy_menu",
      "label": "Select Policy Menu",
      "info": "Add Privacy Policy, Terms, etc. here."
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Link Hover Color",
      "default": "#c49a5e"
    }
  ],
  "presets": [
    {
      "name": "Simple Center Footer"
    }
  ]
}
{% endschema %}