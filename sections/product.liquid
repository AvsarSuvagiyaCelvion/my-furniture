{%- comment -%} Professional Product Detail Page — Refined & Modern {%- endcomment -%}

<section class="product-page" style="--product-accent: {{ section.settings.accent_color }};">

  <!-- Breadcrumb: Minimalist & Clean -->
  <nav class="pdp-breadcrumb" aria-label="Breadcrumb">
    <div class="pdp-breadcrumb__inner">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="pdp-breadcrumb__sep">/</span>
      {%- for collection in product.collections limit: 1 -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span class="pdp-breadcrumb__sep">/</span>
      {%- endfor -%}
      <span class="pdp-breadcrumb__current">{{ product.title }}</span>
    </div>
  </nav>

  <div class="product-page__inner">

    <!-- ── Left: Premium Image Gallery ───────────────────── -->
    <div class="product-gallery">
      <div class="product-gallery__sticky">
        <div class="product-gallery__main">
          <div class="product-gallery__main-img-wrap" id="main-img-wrap">
            {%- if product.featured_image -%}
              {{-
                product.featured_image
                | image_url: width: 1000, format: 'webp'
                | image_tag:
                  class: 'product-gallery__main-img',
                  id: 'main-product-image',
                  alt: product.title,
                  loading: 'eager'
              -}}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'product-gallery__placeholder' }}
            {%- endif -%}
            
            {%- if product.compare_at_price > product.price -%}
              {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
              <span class="pdp-badge-sale">SAVE {{ savings }}%</span>
            {%- endif -%}
          </div>
        </div>

        {%- if product.images.size > 1 -%}
          <div class="product-gallery__thumbs">
            {%- for image in product.images -%}
              <button
                type="button"
                class="thumb-item {% if forloop.first %}is-active{% endif %}"
                data-src="{{ image | image_url: width: 1000, format: 'webp' }}"
                data-alt="{{ image.alt | escape }}"
              >
                <img src="{{ image | image_url: width: 120, height: 120, crop: 'center' }}" alt="{{ image.alt }}" loading="lazy" width="120" height="120">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- ── Right: Modern Product Details ─────────────────── -->
    <div class="product-page__details">
      <div class="product-details__header">
        {%- if product.vendor != blank -%}
          <span class="product-vendor">{{ product.vendor }}</span>
        {%- endif -%}
        <h1 class="product-title">{{ product.title }}</h1>

        <div class="product-price-row">
          <span class="price-main">{{ product.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="price-compare">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
        </div>
      </div>

      <div class="product-description rte">
        {{ product.description }}
      </div>

      <div class="product-form-container">
        {% form 'product', product %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          {%- if product.variants.size > 1 -%}
            <div class="form-field">
              <label class="field-label">Select Option</label>
              <div class="custom-select">
                <select name="id" class="variant-select">
                  {% for variant in product.variants %}
                    <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                      {{ variant.title }} — {{ variant.price | money }}
                    </option>
                  {% endfor %}
                </select>
                <svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            </div>
          {%- endif -%}

          <div class="form-field">
            <label class="field-label">Quantity</label>
            <div class="qty-selector">
              <button type="button" class="qty-btn" data-action="minus">−</button>
              <input type="number" name="quantity" value="1" min="1" class="qty-input">
              <button type="button" class="qty-btn" data-action="plus">+</button>
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn-add-to-cart" {% unless product.available %}disabled{% endunless %}>
              {% if product.available %}Add to Bag{% else %}Sold Out{% endif %}
            </button>
            <div class="pdp-dynamic-checkout">
              {{ form | payment_button }}
            </div>
          </div>
        {% endform %}
      </div>

      <!-- Trust Bar: Elegant Icons -->
      <div class="trust-bar">
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Secure Checkout</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 12 23 17 16 17 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <span>Fast Shipping</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  :root {
    --pdp-bg: #ffffff;
    --pdp-text: #1a1a1a;
    --pdp-text-light: #666666;
    --pdp-border: #e8e8e8;
    --radius-lg: 12px;
    --radius-sm: 8px;
  }

  .product-page {
    background: var(--pdp-bg);
    padding: 40px 0;
    color: var(--pdp-text);
  }

  .product-page__inner {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
  }

  /* ── Breadcrumb ── */
  .pdp-breadcrumb { margin-bottom: 30px; border-bottom: 1px solid var(--pdp-border); padding-bottom: 15px; }
  .pdp-breadcrumb__inner { max-width: 1300px; margin: 0 auto; padding: 0 24px; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: var(--pdp-text-light); }
  .pdp-breadcrumb__inner a { text-decoration: none; color: inherit; transition: color 0.2s; }
  .pdp-breadcrumb__inner a:hover { color: var(--product-accent); }
  .pdp-breadcrumb__sep { margin: 0 8px; opacity: 0.4; }
  .pdp-breadcrumb__current { font-weight: 700; color: var(--pdp-text); }

  /* ── Gallery ── */
  .product-gallery__sticky { position: sticky; top: 100px; }
  .product-gallery__main { 
    background: #fbfbfb; 
    border-radius: var(--radius-lg); 
    overflow: hidden; 
    margin-bottom: 15px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.02);
  }
  .product-gallery__main-img-wrap { position: relative; aspect-ratio: 4/5; }
  .product-gallery__main-img { width: 100%; height: 100%; object-fit: cover; transition: opacity 0.4s ease; }
  
  .pdp-badge-sale {
    position: absolute; top: 20px; left: 20px;
    background: #000; color: #fff;
    padding: 6px 12px; font-size: 11px; font-weight: 700; border-radius: 4px;
  }

  .product-gallery__thumbs { display: flex; gap: 12px; flex-wrap: wrap; }
  .thumb-item { 
    width: 80px; height: 100px; border-radius: var(--radius-sm); border: 1px solid var(--pdp-border);
    overflow: hidden; cursor: pointer; background: none; padding: 0; transition: 0.3s;
  }
  .thumb-item img { width: 100%; height: 100%; object-fit: cover; }
  .thumb-item.is-active { border-color: var(--product-accent); box-shadow: 0 0 0 1px var(--product-accent); }

  /* ── Product Info ── */
  .product-vendor { display: block; font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--product-accent); letter-spacing: 2px; margin-bottom: 10px; }
  .product-title { font-size: 34px; font-weight: 800; line-height: 1.2; margin: 0 0 15px; letter-spacing: -0.5px; }
  
  .product-price-row { display: flex; align-items: center; gap: 15px; margin-bottom: 25px; }
  .price-main { font-size: 24px; font-weight: 700; color: var(--pdp-text); }
  .price-compare { font-size: 18px; text-decoration: line-through; color: #767676; } /* #767676 = 4.54:1 on white — WCAG AA */

  .product-description { font-size: 15px; line-height: 1.6; color: var(--pdp-text-light); margin-bottom: 30px; }

  /* ── Form Elements ── */
  .form-field { margin-bottom: 20px; }
  .field-label { display: block; font-size: 11px; font-weight: 700; text-transform: uppercase; margin-bottom: 8px; color: #767676; } /* #767676 = 4.54:1 on white — WCAG AA */
  
  .custom-select { position: relative; }
  .variant-select { 
    width: 100%; padding: 14px; border: 1px solid var(--pdp-border); border-radius: var(--radius-sm);
    appearance: none; font-size: 14px; cursor: pointer; transition: 0.3s;
  }
  .variant-select:focus { outline: none; border-color: var(--product-accent); }
  .custom-select svg { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); pointer-events: none; }

  .qty-selector { display: flex; width: 130px; border: 1px solid var(--pdp-border); border-radius: var(--radius-sm); }
  .qty-btn { width: 40px; height: 45px; border: none; background: none; cursor: pointer; font-size: 18px; }
  .qty-input { width: 50px; border: none; text-align: center; font-weight: 700; -moz-appearance: textfield; }
  .qty-input::-webkit-inner-spin-button { display: none; }

  /* ── Action Buttons ── */
  .form-actions { margin-top: 35px; display: flex; flex-direction: column; gap: 12px; }
  .btn-add-to-cart { 
    background: #000; color: #fff; border: none; padding: 18px; 
    border-radius: var(--radius-sm); font-weight: 700; text-transform: uppercase;
    letter-spacing: 1px; cursor: pointer; transition: 0.3s;
  }
  .btn-add-to-cart:hover { background: var(--product-accent); transform: translateY(-2px); }
  
  .pdp-dynamic-checkout .shopify-payment-button__button--unbranded { 
    border-radius: var(--radius-sm) !important; padding: 18px !important;
  }

  /* ── Trust Bar ── */
  .trust-bar { display: flex; gap: 30px; margin-top: 40px; padding-top: 30px; border-top: 1px solid var(--pdp-border); }
  .trust-item { display: flex; align-items: center; gap: 10px; font-size: 13px; font-weight: 600; }
  .trust-item svg { width: 20px; height: 20px; color: var(--product-accent); }

  @media (max-width: 900px) {
    .product-page__inner { grid-template-columns: 1fr; }
    .product-gallery__sticky { position: static; }
    .product-title { font-size: 28px; }
  }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Gallery Switcher
    const mainImg = document.getElementById('main-product-image');
    const thumbs = document.querySelectorAll('.thumb-item');

    thumbs.forEach(thumb => {
      thumb.addEventListener('click', function() {
        const newSrc = this.dataset.src;
        mainImg.style.opacity = '0';
        
        setTimeout(() => {
          mainImg.src = newSrc;
          mainImg.style.opacity = '1';
        }, 200);

        thumbs.forEach(t => t.classList.remove('is-active'));
        this.classList.add('is-active');
      });
    });

    // Quantity Logic
    const qtyInput = document.querySelector('.qty-input');
    const qtyBtns = document.querySelectorAll('.qty-btn');

    qtyBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        let val = parseInt(qtyInput.value);
        if (this.dataset.action === 'plus') {
          qtyInput.value = val + 1;
        } else if (val > 1) {
          qtyInput.value = val - 1;
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Professional Product Page",
  "settings": [
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#c49a5e"
    }
  ],
  "presets": [
    {
      "name": "Professional Product Page"
    }
  ]
}
{% endschema %}