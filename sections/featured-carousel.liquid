{%- comment -%} Poore store ki products ko latest date ke hisaab se sort kar rahe hain {%- endcomment -%}
{%- assign latest_products = collections.all.products | sort: 'published_at' | reverse -%}

<section class="featured-products-slider section-{{ section.id }}">
  <div class="container">
    <div class="section-header">
      <h2 class="title">{{ section.settings.title }}</h2>
      <p class="subtitle">{{ section.settings.subtitle }}</p>
    </div>

    <!-- Swiper Slider Container -->
    <div class="swiper latest-products-swiper">
      <div class="swiper-wrapper">
        {%- comment -%} Sirf pehli 4 products ka loop {%- endcomment -%}
        {% for product in latest_products limit: 4 %}
          <div class="swiper-slide">
            <div class="product-card">
              <a href="{{ product.url }}" class="product-link">
                <div class="product-image-box">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="badge sale">New Drop</span>
                  {%- endif -%}

                  {{-
                    product.featured_image
                    | image_url: width: 600, format: 'webp'
                    | image_tag:
                      class: 'primary-img',
                      alt: product.title,
                      loading: 'lazy',
                      width: 600,
                      height: 600
                  -}}

                  {%- if product.images.size > 1 -%}
                    {{-
                      product.images[1]
                      | image_url: width: 600, format: 'webp'
                      | image_tag:
                        class: 'secondary-img',
                        alt: product.title,
                        loading: 'lazy',
                        width: 600,
                        height: 600
                    -}}
                  {%- endif -%}

                  <div class="quick-add">
                    <span>View Detail</span>
                  </div>
                </div>

                <div class="product-info">
                  <h3 class="product-title">{{ product.title }}</h3>
                  <div class="product-price">
                    <span class="current-price">{{ product.price | money }}</span>
                    {% if product.compare_at_price > product.price %}
                      <span class="old-price">{{ product.compare_at_price | money }}</span>
                    {% endif %}
                  </div>
                </div>
              </a>
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Navigation Arrows -->
      <div class="swiper-button-next custom-nav"></div>
      <div class="swiper-button-prev custom-nav"></div>
    </div>
  </div>
</section>

{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>

<style>
  .featured-products-slider {
    padding: 100px 0;
    background: #fff;
  }
  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
  }

  .section-header {
    text-align: left;
    margin-bottom: 40px;
    border-left: 5px solid #222;
    padding-left: 20px;
  }
  .section-header .title {
    font-size: 2.8rem;
    margin: 0;
    font-weight: 800;
    letter-spacing: -1px;
  }
  .section-header .subtitle {
    color: #888;
    margin-top: 5px;
    font-size: 1rem;
  }

  .product-card {
    background: #fff;
    position: relative;
    overflow: hidden;
  }
  .product-image-box {
    position: relative;
    aspect-ratio: 1/1;
    overflow: hidden;
    background: #f9f9f9;
    border-radius: 4px;
  }

  .product-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .secondary-img {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
  }

  .product-card:hover .secondary-img {
    opacity: 1;
  }
  .product-card:hover .primary-img {
    transform: scale(1.08);
  }

  .quick-add {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: #222;
    color: #fff;
    padding: 12px 25px;
    white-space: nowrap;
    transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 1px;
  }
  .product-card:hover .quick-add {
    transform: translateX(-50%) translateY(0);
  }

  .product-info {
    padding: 20px 0;
  }
  .product-title {
    font-size: 1.1rem;
    margin-bottom: 8px;
    color: #111;
    font-weight: 600;
  }
  .product-price {
    font-size: 1.2rem;
    color: #444;
  }
  .old-price {
    text-decoration: line-through;
    color: #bbb;
    margin-left: 8px;
    font-size: 0.9rem;
  }

  .badge {
    position: absolute;
    top: 15px;
    left: 15px;
    background: #000;
    color: #fff;
    padding: 4px 12px;
    font-size: 10px;
    font-weight: 700;
    z-index: 2;
    text-transform: uppercase;
  }

  .custom-nav {
    background: #fff;
    width: 50px !important;
    height: 50px !important;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    border-radius: 50%;
    top: 40% !important;
  }
  .custom-nav::after {
    font-size: 1.2rem !important;
    color: #000;
  }
  .swiper-button-next {
    right: -10px !important;
  }
  .swiper-button-prev {
    left: -10px !important;
  }

  @media (max-width: 768px) {
    .section-header .title {
      font-size: 2rem;
    }
    .custom-nav {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.latest-products-swiper', {
      slidesPerView: 1.2,
      spaceBetween: 20,
      centeredSlides: false,
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      breakpoints: {
        640: { slidesPerView: 2.2 },
        1024: { slidesPerView: 3 },
        1200: { slidesPerView: 4 },
      },
    });
  });
</script>

{% schema %}
{
  "name": "Latest 4 Products Slider",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Latest Collection"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Just added to our store"
    }
  ],
  "presets": [
    {
      "name": "Latest 4 Products Slider"
    }
  ]
}
{% endschema %}
