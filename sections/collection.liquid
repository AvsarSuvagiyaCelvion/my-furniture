{%- comment -%} ── Single Collection (Product Grid) Page ────────────────────── {%- endcomment -%}

{% paginate collection.products by 12 %}
  <div class="coll-hero coll-hero--plain">
    <div class="coll-hero__content">
      <nav class="coll-hero__breadcrumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}" class="coll-hero__breadcrumb-link">Home</a>
        <span aria-hidden="true"> / </span>
        <a href="/collections" class="coll-hero__breadcrumb-link">Collections</a>
        <span aria-hidden="true"> / </span>
        <span aria-current="page">{{ collection.title }}</span>
      </nav>
      <h1 class="coll-hero__title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="coll-hero__desc">{{ collection.description }}</div>
      {% endif %}
    </div>
  </div>

  <div class="coll-main">
    <div class="product-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
      {% for product in collection.products %}
        <div class="product-card">
          <a href="{{ product.url }}" style="text-decoration: none; color: inherit;">
            <div class="product-card__image" style="aspect-ratio: 1/1; overflow: hidden; background: #f0f0f0;">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.title }}" style="width: 100%; height: 100%; object-fit: cover;">
              {% else %}
                {{ 'product-1' | placeholder_svg_tag }}
              {% endif %}
            </div>
            <div class="product-card__info" style="padding: 10px 0;">
              <h3 style="margin: 0; font-size: 1.1rem;">{{ product.title }}</h3>
              <p style="margin: 5px 0; font-weight: bold;">{{ product.price | money }}</p>
            </div>
          </a>
        </div>
      {% else %}
        <p style="text-align: center; width: 100%;">No products found in this collection.</p>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
      <div class="pagination" style="text-align: center; margin-top: 50px;">
        {{ paginate | default_pagination }}
      </div>
    {% endif %}
  </div>
{% endpaginate %}

<style>
  /* Aap wahi CSS reuse kar sakte hain jo upar hero section ke liye thi */
  .product-grid { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    gap: 30px; 
  }
  @media (max-width: 768px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>