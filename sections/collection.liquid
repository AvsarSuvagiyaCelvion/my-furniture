{%- comment -%} ── Single Collection Products Page ──────────────── {%- endcomment -%}

{%- paginate collection.products by section.settings.products_per_page -%}

  {%- comment -%} ── HERO: Full-width image banner ── {%- endcomment -%}
  <div class="ch-hero">
    {%- if collection.image != blank -%}
      {{-
        collection.image
        | image_url: width: 1800, format: 'webp'
        | image_tag:
          class: 'ch-hero__img',
          alt: collection.title,
          loading: 'eager',
          fetchpriority: 'high'
      -}}
    {%- else -%}
      <div class="ch-hero__img ch-hero__img--fallback"></div>
    {%- endif -%}

    <div class="ch-hero__overlay"></div>

    <div class="ch-hero__content">
      <nav class="ch-hero__breadcrumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}" class="ch-hero__bc-link">Home</a>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <a href="{{ routes.collections_url }}" class="ch-hero__bc-link">Collections</a>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span aria-current="page">{{ collection.title }}</span>
      </nav>

      <h1 class="ch-hero__title">{{ collection.title }}</h1>

      {%- if collection.description != blank -%}
        <p class="ch-hero__desc">{{ collection.description | strip_html | truncatewords: 18 }}</p>
      {%- endif -%}

      <div class="ch-hero__meta">
        <span class="ch-hero__badge">{{ collection.products_count }} Products</span>
      </div>
    </div>
  </div>

  {%- comment -%} ── TOOLBAR: sort + results ── {%- endcomment -%}
  <div class="ch-toolbar">
    <div class="ch-toolbar__inner">
      <p class="ch-toolbar__count" aria-live="polite">
        Showing
        <strong>{{ paginate.current_offset | plus: 1 }}–{{ paginate.current_offset | plus: collection.products.size }}</strong>
        of <strong>{{ collection.products_count }}</strong> products
      </p>

      <div class="ch-toolbar__sort">
        <label for="ch-sort" class="ch-toolbar__sort-label">Sort</label>
        <div class="ch-sort-wrap">
          <select
            id="ch-sort"
            class="ch-sort-select"
            onchange="window.location.href = this.value"
            aria-label="Sort products"
          >
            {%- for option in collection.sort_options -%}
              <option
                value="{{ collection.url }}?sort_by={{ option.value }}"
                {%- if collection.sort_by == option.value %} selected{%- endif -%}
              >{{ option.name }}</option>
            {%- endfor -%}
          </select>
          <svg class="ch-sort-chevron" width="11" height="7" viewBox="0 0 11 7" fill="none" aria-hidden="true">
            <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ── PRODUCTS GRID ── {%- endcomment -%}
  <main class="ch-main" id="collection-products">
    {%- if collection.products.size > 0 -%}

      <div
        class="ch-grid"
        style="--cols-desk:{{ section.settings.columns_desktop }};--cols-mob:{{ section.settings.columns_mobile }};"
      >
        {%- for product in collection.products -%}
          <article class="ch-card" aria-label="{{ product.title }}">

            {%- comment -%} Image area with overlay {%- endcomment -%}
            <a href="{{ product.url }}" class="ch-card__media-link" tabindex="-1" aria-hidden="true">
              <div class="ch-card__media">

                {%- comment -%} Main image {%- endcomment -%}
                {%- if product.featured_image != blank -%}
                  {{-
                    product.featured_image
                    | image_url: width: 700, format: 'webp'
                    | image_tag:
                      class: 'ch-card__img',
                      alt: product.featured_image.alt | default: product.title,
                      loading: 'lazy',
                      width: 700,
                      height: 700
                  -}}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'ch-card__img ch-card__img--placeholder' }}
                {%- endif -%}

                {%- comment -%} Hover second image {%- endcomment -%}
                {%- if product.images.size > 1 -%}
                  {{-
                    product.images[1]
                    | image_url: width: 700, format: 'webp'
                    | image_tag:
                      class: 'ch-card__img ch-card__img--hover',
                      alt: product.title,
                      loading: 'lazy',
                      width: 700,
                      height: 700
                  -}}
                {%- endif -%}

                {%- comment -%} Badges {%- endcomment -%}
                <div class="ch-card__badges">
                  {%- if product.available == false -%}
                    <span class="ch-card__badge ch-card__badge--sold">Sold Out</span>
                  {%- elsif product.compare_at_price > product.price -%}
                    {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                    <span class="ch-card__badge ch-card__badge--sale">-{{ discount }}%</span>
                  {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
                    <span class="ch-card__badge ch-card__badge--new">New</span>
                  {%- endif -%}
                </div>

                {%- comment -%} Hover overlay with info ── {%- endcomment -%}
                <div class="ch-card__overlay" aria-hidden="true">
                  <div class="ch-card__overlay-inner">
                    {%- if product.vendor != blank -%}
                      <p class="ch-card__vendor">{{ product.vendor }}</p>
                    {%- endif -%}
                    <h2 class="ch-card__title">{{ product.title }}</h2>
                    <div class="ch-card__price">
                      {%- if product.compare_at_price > product.price -%}
                        <s class="ch-card__price-was">{{ product.compare_at_price | money }}</s>
                        <span class="ch-card__price-now ch-card__price-now--sale">{{ product.price | money }}</span>
                      {%- else -%}
                        <span class="ch-card__price-now">{{ product.price | money }}</span>
                      {%- endif -%}
                    </div>
                  </div>
                </div>

              </div>
            </a>

            {%- comment -%} Card footer below image {%- endcomment -%}
            <div class="ch-card__foot">
              <div class="ch-card__foot-info">
                <a href="{{ product.url }}" class="ch-card__foot-title">{{ product.title }}</a>
                <div class="ch-card__foot-price">
                  {%- if product.compare_at_price > product.price -%}
                    <s class="ch-card__foot-was">{{ product.compare_at_price | money }}</s>
                    <span class="ch-card__foot-sale">{{ product.price | money }}</span>
                  {%- else -%}
                    <span>{{ product.price | money }}</span>
                  {%- endif -%}
                </div>
              </div>

              {%- unless product.available == false -%}
                <form method="post" action="{{ routes.cart_add_url }}" class="ch-card__atc-form">
                  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                  <button
                    type="submit"
                    class="ch-card__atc"
                    aria-label="Add {{ product.title }} to cart"
                  >
                    <svg width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true">
                      <path d="M1 1h2.5l1.6 7.5h7.8l1.3-5H4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      <circle cx="7" cy="14.5" r="1" fill="currentColor"/>
                      <circle cx="12" cy="14.5" r="1" fill="currentColor"/>
                    </svg>
                    <span>Add to Cart</span>
                  </button>
                </form>
              {%- else -%}
                <span class="ch-card__sold">Sold Out</span>
              {%- endunless -%}
            </div>

          </article>
        {%- endfor -%}
      </div>

      {%- comment -%} ── Pagination ── {%- endcomment -%}
      {%- if paginate.pages > 1 -%}
        <nav class="ch-pagination" aria-label="Collection pages">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="ch-pagination__arrow" aria-label="Previous page">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          {%- else -%}
            <span class="ch-pagination__arrow ch-pagination__arrow--disabled" aria-disabled="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          {%- endif -%}

          <div class="ch-pagination__pages">
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="ch-pagination__page">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}
                <span class="ch-pagination__page ch-pagination__page--active" aria-current="page">{{ part.title }}</span>
              {%- else -%}
                <span class="ch-pagination__ellipsis">…</span>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="ch-pagination__arrow" aria-label="Next page">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          {%- else -%}
            <span class="ch-pagination__arrow ch-pagination__arrow--disabled" aria-disabled="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          {%- endif -%}
        </nav>
      {%- endif -%}

    {%- else -%}
      <div class="ch-empty">
        <div class="ch-empty__icon">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none" aria-hidden="true">
            <circle cx="28" cy="28" r="26" stroke="#c49a5e" stroke-width="1.5" stroke-dasharray="4 4"/>
            <path d="M20 28h16M28 20v16" stroke="#c49a5e" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h2 class="ch-empty__title">No products here yet</h2>
        <p class="ch-empty__text">This collection is empty — check back soon.</p>
        <a href="{{ routes.collections_url }}" class="ch-empty__btn">Browse all collections</a>
      </div>
    {%- endif -%}
  </main>

{%- endpaginate -%}

{% stylesheet %}

  /* ════════════════════════════════════════
     HERO
  ════════════════════════════════════════ */
  .ch-hero {
    position: relative;
    width: 100%;
    min-height: 320px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: #1a1206;
  }

  @media (min-width: 768px) {
    .ch-hero { min-height: 420px; }
  }

  .ch-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.04);
    transition: transform 8s ease;
  }

  .ch-hero:hover .ch-hero__img {
    transform: scale(1);
  }

  .ch-hero__img--fallback {
    background: linear-gradient(135deg, #2c1f0e 0%, #5a3d1e 50%, #8b5e2a 100%);
  }

  .ch-hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top,  rgba(10,6,0,0.82) 0%,  rgba(10,6,0,0.35) 50%, rgba(10,6,0,0.10) 100%),
      linear-gradient(to right, rgba(10,6,0,0.25) 0%, transparent 60%);
    z-index: 1;
  }

  .ch-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 3rem;
    color: #fff;
  }

  @media (min-width: 768px) {
    .ch-hero__content { padding: 3rem 2.5rem 3.5rem; }
  }

  .ch-hero__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.65);
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .ch-hero__bc-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }

  .ch-hero__bc-link:hover { color: #c49a5e; }

  .ch-hero__title {
    font-size: clamp(2.25rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 0.875rem;
    color: #fff;
    text-shadow: 0 2px 24px rgba(0,0,0,0.4);
  }

  .ch-hero__desc {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.78);
    max-width: 520px;
    margin: 0 0 1.25rem;
  }

  .ch-hero__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .ch-hero__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.9rem;
    background: rgba(196,154,94,0.22);
    border: 1px solid rgba(196,154,94,0.55);
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #e8c27a;
    letter-spacing: 0.03em;
    backdrop-filter: blur(6px);
  }

  /* ════════════════════════════════════════
     TOOLBAR
  ════════════════════════════════════════ */
  .ch-toolbar {
    position: sticky;
    top: 72px;
    z-index: 20;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,0,0,0.07);
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
  }

  .ch-toolbar__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .ch-toolbar__count {
    font-size: 0.875rem;
    color: #666;
    margin: 0;
  }

  .ch-toolbar__count strong {
    color: #1a1a1a;
    font-weight: 600;
  }

  .ch-toolbar__sort {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .ch-toolbar__sort-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .ch-sort-wrap {
    position: relative;
  }

  .ch-sort-select {
    appearance: none;
    -webkit-appearance: none;
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.12);
    border-radius: 10px;
    padding: 0.5rem 2.25rem 0.5rem 0.9rem;
    font-size: 0.875rem;
    font-family: inherit;
    color: #1a1a1a;
    cursor: pointer;
    min-width: 170px;
    transition: border-color 0.18s, box-shadow 0.18s;
  }

  .ch-sort-select:focus {
    outline: none;
    border-color: #c49a5e;
    box-shadow: 0 0 0 3px rgba(196,154,94,0.18);
  }

  .ch-sort-chevron {
    position: absolute;
    right: 0.8rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #888;
  }

  /* ════════════════════════════════════════
     MAIN + GRID
  ════════════════════════════════════════ */
  .ch-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
  }

  .ch-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols-mob, 2), 1fr);
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .ch-grid { gap: 1.25rem; }
  }

  @media (min-width: 1024px) {
    .ch-grid {
      grid-template-columns: repeat(var(--cols-desk, 4), 1fr);
      gap: 1.5rem;
    }
  }

  /* ════════════════════════════════════════
     CARD
  ════════════════════════════════════════ */
  .ch-card {
    display: flex;
    flex-direction: column;
    border-radius: 14px;
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    transition: box-shadow 0.3s ease, transform 0.3s cubic-bezier(0.22,1,0.36,1);
  }

  .ch-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.12), 0 4px 12px rgba(196,154,94,0.1);
  }

  /* ── Media (image area) ── */
  .ch-card__media-link {
    display: block;
    text-decoration: none;
  }

  .ch-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f5f0ea;
  }

  .ch-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.55s cubic-bezier(0.22,1,0.36,1), opacity 0.4s ease;
  }

  .ch-card__img--placeholder {
    opacity: 0.2;
  }

  .ch-card__img--hover {
    opacity: 0;
    z-index: 1;
  }

  .ch-card:hover .ch-card__img--hover {
    opacity: 1;
  }

  .ch-card:hover .ch-card__img:not(.ch-card__img--hover) {
    transform: scale(1.07);
  }

  /* ── Badges ── */
  .ch-card__badges {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .ch-card__badge {
    display: inline-block;
    padding: 0.22rem 0.6rem;
    border-radius: 6px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.4;
  }

  .ch-card__badge--sale {
    background: #c49a5e;
    color: #fff;
  }

  .ch-card__badge--sold {
    background: rgba(0,0,0,0.72);
    color: #fff;
  }

  .ch-card__badge--new {
    background: #2d6a4f;
    color: #fff;
  }

  /* ── Overlay (shown on hover) ── */
  .ch-card__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
    background: linear-gradient(
      to top,
      rgba(14,8,0,0.82) 0%,
      rgba(14,8,0,0.45) 45%,
      transparent 75%
    );
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.22,1,0.36,1);
    pointer-events: none;
  }

  .ch-card:hover .ch-card__overlay {
    opacity: 1;
    transform: translateY(0);
  }

  .ch-card__overlay-inner {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    color: #fff;
  }

  .ch-card__vendor {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #c49a5e;
    margin: 0;
  }

  .ch-card__title {
    font-size: 0.975rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
    color: #fff;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ch-card__price {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.2rem;
  }

  .ch-card__price-now {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }

  .ch-card__price-now--sale { color: #f0c070; }

  .ch-card__price-was {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
    text-decoration: line-through;
    font-weight: 400;
  }

  /* ── Footer below image ── */
  .ch-card__foot {
    padding: 0.875rem 1rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border-top: 1px solid rgba(0,0,0,0.05);
  }

  .ch-card__foot-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .ch-card__foot-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1a1a;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s;
    display: block;
  }

  .ch-card__foot-title:hover { color: #c49a5e; }

  .ch-card__foot-price {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .ch-card__foot-was {
    font-size: 0.8rem;
    font-weight: 400;
    color: #aaa;
    text-decoration: line-through;
  }

  .ch-card__foot-sale { color: #c0392b; }

  /* ── Add to Cart button ── */
  .ch-card__atc-form { flex-shrink: 0; }

  .ch-card__atc {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 0.9rem;
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease, transform 0.18s ease, box-shadow 0.18s ease;
    letter-spacing: 0.02em;
  }

  .ch-card__atc:hover {
    background: #c49a5e;
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(196,154,94,0.35);
  }

  .ch-card__atc svg { flex-shrink: 0; }

  .ch-card__sold {
    font-size: 0.8rem;
    font-weight: 600;
    color: #aaa;
    white-space: nowrap;
  }

  /* ── Hide ATC text on small cards to avoid overflow ── */
  @media (max-width: 480px) {
    .ch-card__atc span { display: none; }
    .ch-card__atc { padding: 0.55rem; }
  }

  /* ════════════════════════════════════════
     PAGINATION
  ════════════════════════════════════════ */
  .ch-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    margin-top: 3.5rem;
    flex-wrap: wrap;
  }

  .ch-pagination__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    border: 1.5px solid rgba(0,0,0,0.12);
    color: #1a1a1a;
    text-decoration: none;
    transition: border-color 0.18s, background 0.18s, color 0.18s;
  }

  .ch-pagination__arrow:hover {
    border-color: #c49a5e;
    color: #c49a5e;
    background: rgba(196,154,94,0.08);
  }

  .ch-pagination__arrow--disabled {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }

  .ch-pagination__pages {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin: 0 0.25rem;
  }

  .ch-pagination__page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 0.5rem;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    color: #1a1a1a;
    border: 1.5px solid transparent;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  a.ch-pagination__page:hover {
    border-color: rgba(196,154,94,0.4);
    color: #c49a5e;
    background: rgba(196,154,94,0.07);
  }

  .ch-pagination__page--active {
    background: #c49a5e;
    color: #fff;
    font-weight: 700;
    border-color: #c49a5e;
  }

  .ch-pagination__ellipsis {
    padding: 0 0.25rem;
    color: #aaa;
    font-size: 0.9rem;
    user-select: none;
  }

  /* ════════════════════════════════════════
     EMPTY STATE
  ════════════════════════════════════════ */
  .ch-empty {
    text-align: center;
    padding: 5rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .ch-empty__icon { margin-bottom: 0.5rem; }

  .ch-empty__title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
  }

  .ch-empty__text {
    font-size: 1rem;
    color: #888;
    margin: 0;
  }

  .ch-empty__btn {
    display: inline-flex;
    align-items: center;
    margin-top: 0.5rem;
    padding: 0.75rem 1.75rem;
    background: #c49a5e;
    color: #fff;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    transition: filter 0.18s, transform 0.18s, box-shadow 0.18s;
  }

  .ch-empty__btn:hover {
    filter: brightness(1.08);
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(196,154,94,0.4);
  }

{% endstylesheet %}

