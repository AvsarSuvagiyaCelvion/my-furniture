{%- comment -%} ── Collections Listing ────────────────────── {%- endcomment -%}

{%- comment -%} ── Page header ── {%- endcomment -%}
<div class="coll-hero coll-hero--plain">
  <div class="coll-hero__content">
    <nav class="coll-hero__breadcrumb" aria-label="{{ 'collection.breadcrumb' | t }}">
      <a href="{{ routes.root_url }}" class="coll-hero__breadcrumb-link">{{ 'general.home' | t }}</a>
      <span aria-hidden="true"> / </span>
      <span aria-current="page">{{ 'collections.title' | t }}</span>
    </nav>
    <h1 class="coll-hero__title">{{ 'collections.title' | t }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="coll-hero__desc">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>
</div>

{%- comment -%} ── Collections grid ── {%- endcomment -%}
<div class="coll-main">
  <div
    class="coll-grid"
    style="--cols-desk: {{ section.settings.columns_desktop }}; --cols-mob: {{ section.settings.columns_mobile }};"
  >
    {%- for coll in collections -%}
      {%- unless coll.handle == 'frontpage' -%}
        {%- assign stagger = forloop.index0 | modulo: 4 | times: 100 -%}
        <div class="coll-card coll-card--reveal" style="--stagger: {{ stagger }}ms;">
          <a href="{{ coll.url }}" class="coll-card__link" aria-label="{{ coll.title }}">

            <div class="coll-card__media">
              {%- if coll.image != blank -%}
                {%- assign img_alt = coll.image.alt | default: coll.title | escape -%}
                {{-
                  coll.image
                  | image_url: width: 800, format: 'webp'
                  | image_tag:
                    class: 'coll-card__img',
                    alt: img_alt,
                    loading: 'lazy',
                    widths: '400, 600, 800'
                -}}
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'coll-card__placeholder' }}
              {%- endif -%}

              <div class="coll-card__overlay">
                <div class="coll-card__overlay-body">
                  <h2 class="coll-card__name">{{ coll.title }}</h2>
                  {%- if section.settings.show_product_count -%}
                    <p class="coll-card__count">
                      {{ 'collection.products_count' | t: count: coll.all_products_count }}
                    </p>
                  {%- endif -%}
                  <span class="coll-card__cta" aria-hidden="true">
                    {{ 'collection.shop_now' | t }}
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </div>
              </div>
            </div>

          </a>
        </div>
      {%- endunless -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  /* ─────────────────────────────────────────────────────
     Keyframes
  ───────────────────────────────────────────────────── */
  @keyframes coll-hero-in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ─────────────────────────────────────────────────────
     Page header
  ───────────────────────────────────────────────────── */
  .coll-hero--plain {
    background: linear-gradient(135deg, #faf7f4 0%, #f0ebe4 100%);
    display: flex;
    align-items: center;
    min-height: 180px;
  }

  .coll-hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 3rem var(--page-margin);
    animation: coll-hero-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Breadcrumb */
  .coll-hero__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-primary--family);
    font-size: 0.8125rem;
    color: var(--color-foreground);
    opacity: 0.45;
    margin-bottom: 0.75rem;
    letter-spacing: 0.01em;
  }

  .coll-hero__breadcrumb-link {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .coll-hero__breadcrumb-link:hover,
  .coll-hero__breadcrumb-link:focus-visible {
    opacity: 0.7;
    text-decoration: underline;
  }

  /* Title */
  .coll-hero__title {
    font-family: var(--font-primary--family);
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-foreground);
    margin: 0 0 0.5rem;
  }

  .coll-hero__desc {
    font-family: var(--font-primary--family);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-foreground);
    opacity: 0.55;
    margin: 0;
    max-width: 52ch;
  }

  /* ─────────────────────────────────────────────────────
     Main container
  ───────────────────────────────────────────────────── */
  .coll-main {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 3rem var(--page-margin) 5rem;
  }

  /* ─────────────────────────────────────────────────────
     Collections grid
  ───────────────────────────────────────────────────── */
  .coll-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols-mob, 1), 1fr);
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .coll-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .coll-grid {
      grid-template-columns: repeat(var(--cols-desk, 3), 1fr);
      gap: 2rem;
    }
  }

  /* ─────────────────────────────────────────────────────
     Collection card
  ───────────────────────────────────────────────────── */
  .coll-card {
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(30, 20, 10, 0.08);
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .coll-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(30, 20, 10, 0.14);
  }

  /* Reveal animation */
  .coll-card--reveal {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1) var(--stagger, 0ms),
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) var(--stagger, 0ms),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .coll-card--reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .coll-card--reveal.is-visible:hover {
    transform: translateY(-6px);
  }

  /* Link fills the entire card */
  .coll-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  /* ── Media ── */
  .coll-card__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: #e8e1d8;
    width: 100%;
  }

  /* Two-column layout gets a wider aspect ratio */
  @media (min-width: 640px) {
    .coll-grid[style*="--cols-desk: 2"] .coll-card__media {
      aspect-ratio: 3 / 4;
    }
  }

  .coll-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .coll-card:hover .coll-card__img {
    transform: scale(1.07);
  }

  .coll-card__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.18;
    display: block;
  }

  /* ── Overlay ── */
  .coll-card__overlay {
    position: absolute;
    inset: 0;
    /* Gradient: transparent top → dark bottom */
    background: linear-gradient(
      to top,
      rgba(10, 7, 4, 0.85) 0%,
      rgba(10, 7, 4, 0.45) 35%,
      rgba(10, 7, 4, 0.0)  65%
    );
    display: flex;
    align-items: flex-end;
    padding: 1.75rem 1.5rem;
    transition: background 0.4s ease;
  }

  .coll-card:hover .coll-card__overlay {
    background: linear-gradient(
      to top,
      rgba(10, 7, 4, 0.92) 0%,
      rgba(10, 7, 4, 0.55) 40%,
      rgba(10, 7, 4, 0.05) 70%
    );
  }

  .coll-card__overlay-body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    width: 100%;
  }

  .coll-card__name {
    font-family: var(--font-primary--family);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: #ffffff;
    margin: 0;
  }

  .coll-card__count {
    font-family: var(--font-primary--family);
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    letter-spacing: 0.01em;
  }

  /* ── Shop now CTA (slides in on hover) ── */
  .coll-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-primary--family);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #ffffff;
    margin-top: 0.375rem;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  .coll-card:hover .coll-card__cta {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─────────────────────────────────────────────────────
     Mobile
  ───────────────────────────────────────────────────── */
  @media (max-width: 639px) {
    .coll-hero--plain {
      min-height: 140px;
    }

    .coll-main {
      padding-top: 2rem;
      padding-bottom: 3rem;
    }

    .coll-card {
      border-radius: 14px;
    }

    .coll-card__overlay {
      padding: 1.25rem 1rem;
    }

    /* Always show CTA on touch devices (no hover) */
    .coll-card__cta {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ─────────────────────────────────────────────────────
     Reduced motion
  ───────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .coll-card--reveal,
    .coll-card {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .coll-card:hover {
      transform: none;
    }

    .coll-card__img {
      transition: none;
    }

    .coll-card__cta {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var cards = document.querySelectorAll('.coll-card--reveal');

    if (reducedMotion || !('IntersectionObserver' in window)) {
      cards.forEach(function (c) { c.classList.add('is-visible'); });
      return;
    }

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          var el = entry.target;
          el.classList.add('is-visible');
          var delay = parseInt(el.style.getPropertyValue('--stagger') || '0', 10);
          setTimeout(function () {
            el.style.setProperty('--stagger', '0ms');
          }, 700 + delay);
          observer.unobserve(el);
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -20px 0px' }
    );

    cards.forEach(function (c) { observer.observe(c); });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.collection",
  "settings": [
    {
      "type": "header",
      "content": "t:general.content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": ""
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "t:labels.show_product_count",
      "default": true
    },
    {
      "type": "header",
      "content": "t:general.layout"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "t:labels.columns_desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:labels.columns_mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    }
  ]
}
{% endschema %}
