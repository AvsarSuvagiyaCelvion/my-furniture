    }
  ],
  "presets": [
    {
      "name": "t:general.collections_showcase",
      "settings": {
        "heading": "Designed for Every Space",
        "subheading": "Whether it's your living room or workspace, we have the perfect piece for you.",
        "collection_1_label": "Home Collection",
