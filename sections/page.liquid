{%- comment -%} Page template — styled content wrapper (About Us, Contact, etc.) {%- endcomment -%}

<section class="page-section">

  <!-- Hero strip with page title -->
  <div class="page-hero">
    <div class="page-hero__inner">
      <nav class="page-hero__breadcrumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
        <span>{{ page.title }}</span>
      </nav>
      <h1 class="page-hero__title">{{ page.title }}</h1>
      <div class="page-hero__bar" aria-hidden="true"></div>
    </div>
  </div>

  <!-- Content -->
  <div class="page-content-wrap">
    <div class="page-content rte">
      {{ page.content }}
    </div>
  </div>

</section>

<style>
  /* ── Hero ──────────────────────────────────────────────── */
  .page-hero {
    background: #1a1a1a;
    padding: 60px 24px 56px;
    position: relative;
    overflow: hidden;
  }
  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 80% at 0% 100%, rgba(196,154,94,0.14) 0%, transparent 60%);
    pointer-events: none;
  }
  .page-hero__inner {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* Breadcrumb */
  .page-hero__breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }
  .page-hero__breadcrumb a {
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    transition: color 0.2s;
  }
  .page-hero__breadcrumb a:hover { color: #c49a5e; }
  .page-hero__breadcrumb svg { color: rgba(255,255,255,0.25); flex-shrink: 0; }
  .page-hero__breadcrumb span { color: rgba(255,255,255,0.75); }

  .page-hero__title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    margin: 0 0 20px;
    line-height: 1.1;
  }
  .page-hero__bar {
    width: 48px;
    height: 4px;
    background: #c49a5e;
    border-radius: 999px;
  }

  /* ── Content ───────────────────────────────────────────── */
  .page-content-wrap {
    background: #fafaf8;
    padding: 64px 24px 100px;
  }
  .page-content {
    max-width: 760px;
    margin: 0 auto;
  }

  /* Rich text typography */
  .page-content h1,
  .page-content h2,
  .page-content h3,
  .page-content h4 {
    color: #111;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 2em 0 0.6em;
  }
  .page-content h1 { font-size: 2rem; }
  .page-content h2 {
    font-size: 1.5rem;
    padding-left: 16px;
    border-left: 4px solid #c49a5e;
  }
  .page-content h3 { font-size: 1.2rem; color: #333; }

  .page-content p {
    font-size: 1rem;
    line-height: 1.85;
    color: #555;
    margin: 0 0 1.2em;
  }

  .page-content a {
    color: #c49a5e;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .page-content a:hover { color: #a07840; }

  .page-content ul,
  .page-content ol {
    padding-left: 1.4em;
    margin: 0 0 1.2em;
    color: #555;
    line-height: 1.8;
  }
  .page-content li { margin-bottom: 0.4em; }

  .page-content blockquote {
    border-left: 4px solid #c49a5e;
    margin: 2em 0;
    padding: 16px 24px;
    background: rgba(196,154,94,0.06);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: #666;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .page-content img {
    max-width: 100%;
    border-radius: 12px;
    margin: 1.5em 0;
    box-shadow: 0 12px 32px rgba(0,0,0,0.08);
  }

  .page-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-size: 0.9rem;
  }
  .page-content th,
  .page-content td {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid #ebebeb;
  }
  .page-content th {
    font-weight: 700;
    color: #111;
    background: #f4f2ee;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .page-content tr:hover td { background: rgba(196,154,94,0.04); }

  .page-content hr {
    border: none;
    height: 1px;
    background: #ebebeb;
    margin: 2.5em 0;
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 640px) {
    .page-hero { padding: 50px 20px 46px; }
    .page-content-wrap { padding: 48px 20px 80px; }
  }
</style>

{% schema %}
{
  "name": "t:general.page",
  "settings": [],
  "presets": [
    {
      "name": "Page"
    }
  ]
}
{% endschema %}
