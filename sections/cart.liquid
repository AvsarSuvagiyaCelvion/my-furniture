{% comment %}
  Modern & Attractive Cart Template
{% endcomment %}

<div class="cart-container container">
  {% comment %}
    <div class="cart-header">
      <h1>{{ 'cart.title' | t }}</h1>
      <a href="/collections/all" class="continue-shopping">Continue Shopping</a>
    </div>
  {% endcomment %}

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" novalidate>
      <div class="cart-items-wrapper">
        <div class="cart-table-header">
          <span>Product</span>
          <span>Quantity</span>
          <span>Total</span>
        </div>

        {% for item in cart.items %}
          <div class="cart-item">
            <div class="item-info">
              <div class="item-image">
                {% if item.image %}
                  <img
                    src="{{ item.image | image_url: width: 200, height: 200, crop: 'center' }}"
                    alt="{{ item.title | escape }}"
                    loading="lazy"
                    width="100"
                    height="100"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
              <div class="item-details">
                <a href="{{ item.url }}" class="item-title">{{ item.product.title }}</a>
                {% unless item.product.has_only_default_variant %}
                  <p class="item-variant">{{ item.variant.title }}</p>
                {% endunless %}
                <p class="item-price">{{ item.price | money }}</p>
                <a href="{{ item.url_to_remove }}" class="remove-btn">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    fill="currentColor"
                    viewBox="0 0 16 16"
                  >
                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/><path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                  </svg>
                  Remove
                </a>
              </div>
            </div>

            <div class="item-quantity">
              <div class="qty-selector">
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" id="updates_{{ item.key }}">
              </div>
            </div>

            <div class="item-total">
              <span class="total-price">{{ item.final_line_price | money }}</span>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="cart-footer">
        <div class="cart-notes">
          <label for="CartSpecialInstructions">Order Special Instructions</label>
          <textarea name="note" id="CartSpecialInstructions">{{ cart.note }}</textarea>
        </div>

        <div class="cart-summary">
          <div class="summary-row">
            <span>Subtotal</span>
            <span class="subtotal-amount">{{ cart.total_price | money }}</span>
          </div>
          <p class="shipping-info">Taxes and shipping calculated at checkout</p>
          <div class="cart-buttons">
            <button type="submit" name="update" class="btn secondary-btn">{{ 'cart.update' | t }}</button>
            <button type="submit" name="checkout" class="btn primary-btn">{{ 'cart.checkout' | t }}</button>
          </div>
        </div>
      </div>
    </form>
  {% else %}
    <div class="empty-cart-msg">
      <p>Your cart is currently empty.</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn primary-btn">Start Shopping</a>
    </div>
  {% endif %}
</div>

<style>
  :root {
    --primary-color: #000;
    --secondary-color: #555;
    --accent-color: #f4f4f4;
    --border-color: #ddd;
    --text-color: #333;
    --btn-hover: #333;
  }

  .cart-container {
    max-width: 1000px;
    margin: 40px auto;
    padding: 0 20px;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    color: var(--text-color);
  }

  .cart-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 2px solid var(--primary-color);
    margin-bottom: 30px;
    padding-bottom: 10px;
  }

  .cart-header h1 {
    margin: 0;
    font-size: 2rem;
    text-transform: uppercase;
  }

  .continue-shopping {
    text-decoration: underline;
    color: var(--secondary-color);
    font-size: 0.9rem;
  }

  /* Table Header */
  .cart-table-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    padding: 10px 0;
    font-weight: bold;
    border-bottom: 1px solid var(--border-color);
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 1px;
  }

  /* Cart Item Row */
  .cart-item {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    align-items: center;
    padding: 20px 0;
    border-bottom: 1px solid var(--border-color);
  }

  .item-info {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .item-image img {
    width: 100px;
    height: 120px;
    object-fit: cover;
    border-radius: 8px;
    background: #f9f9f9;
  }

  .item-title {
    font-weight: bold;
    font-size: 1.1rem;
    text-decoration: none;
    color: var(--primary-color);
    display: block;
    margin-bottom: 5px;
  }

  .item-variant {
    font-size: 0.85rem;
    color: #777;
    margin: 5px 0;
  }

  .remove-btn {
    font-size: 0.75rem;
    color: #ff4444;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 5px;
    margin-top: 10px;
    transition: 0.3s;
  }

  .remove-btn:hover {
    color: #cc0000;
  }

  /* Quantity & Input */
  .qty-selector input {
    width: 60px;
    padding: 8px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    text-align: center;
  }

  .item-total {
    text-align: right;
    font-weight: bold;
    font-size: 1.1rem;
  }

  /* Footer Section */
  .cart-footer {
    display: flex;
    justify-content: space-between;
    gap: 40px;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .cart-notes {
    flex: 1;
    min-width: 300px;
  }

  .cart-notes label {
    display: block;
    margin-bottom: 10px;
    font-weight: bold;
  }

  .cart-notes textarea {
    width: 100%;
    height: 100px;
    border: 1px solid var(--border-color);
    padding: 10px;
    border-radius: 4px;
  }

  .cart-summary {
    width: 350px;
    background: var(--accent-color);
    padding: 25px;
    border-radius: 12px;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 1.2rem;
    font-weight: bold;
    margin-bottom: 10px;
  }

  .shipping-info {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 20px;
  }

  .btn {
    display: block;
    width: 100%;
    padding: 15px;
    text-align: center;
    text-transform: uppercase;
    font-weight: bold;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: 0.3s ease;
    margin-bottom: 10px;
    font-size: 0.9rem;
    letter-spacing: 1px;
  }

  .primary-btn {
    background: var(--primary-color);
    color: white;
  }

  .primary-btn:hover {
    background: #333;
    transform: translateY(-2px);
  }

  .secondary-btn {
    background: transparent;
    border: 1px solid var(--primary-color);
    color: var(--primary-color);
  }

  .secondary-btn:hover {
    background: #eee;
  }

  /* Empty State */
  .empty-cart-msg {
    text-align: center;
    padding: 100px 0;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .cart-table-header {
      display: none;
    }
    .cart-item {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 15px;
    }
    .item-info {
      flex-direction: column;
    }
    .cart-footer {
      flex-direction: column;
    }
    .cart-summary {
      width: 100%;
    }
    .item-total {
      text-align: center;
      border-top: 1px dashed #ddd;
      padding-top: 10px;
    }
  }
</style>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
