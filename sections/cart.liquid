{%- comment -%} Professional Cart — warm wood tones, animations, trust badges {%- endcomment -%}

<section class="cart-section">
  <div class="cart-wrap">

    <div class="cart-heading">
      <h1 class="cart-title">
        Shopping Cart
        {%- if cart.item_count > 0 -%}
          <span class="cart-count-pill">{{ cart.item_count }}</span>
        {%- endif -%}
      </h1>
      <a href="{{ routes.all_products_collection_url }}" class="cart-continue-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Continue Shopping
      </a>
    </div>

    {%- if cart.item_count > 0 -%}

      <form action="{{ routes.cart_url }}" method="post" novalidate class="cart-form">
        <div class="cart-body">

          <!-- ── LEFT: Items ──────────────────────────────── -->
          <div class="cart-items-col">
            <div class="cart-thead" aria-hidden="true">
              <span class="col-product">Product</span>
              <span class="col-price">Price</span>
              <span class="col-qty">Quantity</span>
              <span class="col-total">Total</span>
            </div>

            {%- for item in cart.items -%}
              <div class="cart-item" style="animation-delay: {{ forloop.index0 | times: 0.08 }}s">

                <div class="cart-item__media">
                  <a href="{{ item.url }}" tabindex="-1" aria-hidden="true">
                    {%- if item.image -%}
                      {{-
                        item.image
                        | image_url: width: 240, format: 'webp'
                        | image_tag:
                          class: 'cart-item__img',
                          alt: item.title,
                          loading: 'lazy',
                          width: 120,
                          height: 140
                      -}}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'cart-item__img cart-item__img--placeholder' }}
                    {%- endif -%}
                  </a>
                </div>

                <div class="cart-item__details">
                  <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  <p class="cart-item__unit-price">{{ item.price | money }}</p>
                  <a href="{{ item.url_to_remove }}" class="cart-item__remove" aria-label="Remove {{ item.title | escape }}">
                    <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                      <path d="M1 1l9 9M10 1L1 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                    Remove
                  </a>
                </div>

                <div class="cart-item__price" aria-label="Price per unit">
                  {{ item.price | money }}
                </div>

                <div class="cart-item__qty">
                  <div class="qty-control">
                    <button
                      type="button"
                      class="qty-btn qty-dec"
                      aria-label="Decrease quantity for {{ item.title | escape }}"
                      data-target="updates_{{ item.key }}"
                    >−</button>
                    <input
                      type="number"
                      name="updates[]"
                      id="updates_{{ item.key }}"
                      value="{{ item.quantity }}"
                      min="0"
                      class="qty-input"
                      aria-label="Quantity for {{ item.title | escape }}"
                    >
                    <button
                      type="button"
                      class="qty-btn qty-inc"
                      aria-label="Increase quantity for {{ item.title | escape }}"
                      data-target="updates_{{ item.key }}"
                    >+</button>
                  </div>
                </div>

                <div class="cart-item__line-total">
                  {{ item.final_line_price | money }}
                </div>

              </div>
            {%- endfor -%}
          </div>

          <!-- ── RIGHT: Summary ──────────────────────────── -->
          <div class="cart-summary-col">
            <div class="cart-summary-panel">

              <h2 class="summary-title">Order Summary</h2>

              <div class="summary-row">
                <span>
                  Subtotal
                  ({{ cart.item_count }}
                  {%- if cart.item_count == 1 -%} item{%- else -%} items{%- endif -%})
                </span>
                <strong class="summary-amount">{{ cart.total_price | money }}</strong>
              </div>

              <p class="summary-shipping">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                Shipping & taxes calculated at checkout
              </p>

              <button type="submit" name="checkout" class="checkout-cta">
                Proceed to Checkout
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>

              <button type="submit" name="update" class="update-cart-btn">
                Update Cart
              </button>

              <div class="cart-trust">
                <div class="trust-item">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  Secure Checkout
                </div>
                <div class="trust-item">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 12 23 17 16 17 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  Free Delivery
                </div>
                <div class="trust-item">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4"/></svg>
                  30-Day Returns
                </div>
              </div>

              <details class="cart-note-wrap">
                <summary class="cart-note-toggle">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  Add Order Notes
                </summary>
                <textarea
                  name="note"
                  id="CartSpecialInstructions"
                  class="cart-note-input"
                  placeholder="Gift message, special instructions..."
                  rows="3"
                >{{ cart.note }}</textarea>
              </details>

            </div>
          </div>
        </div>
      </form>

    {%- else -%}

      <div class="cart-empty">
        <div class="cart-empty__icon">
          <svg viewBox="0 0 100 100" fill="none" aria-hidden="true">
            <circle cx="50" cy="50" r="46" stroke="#c49a5e" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.4"/>
            <path d="M28 36h6l8 28h24l6-20H38" stroke="#c49a5e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M24 32h8l2 8" stroke="#c49a5e" stroke-width="2" stroke-linecap="round"/>
            <circle cx="44" cy="66" r="3" fill="#c49a5e"/>
            <circle cx="58" cy="66" r="3" fill="#c49a5e"/>
            <path d="M44 50l6-6 6 6M50 44v16" stroke="#c49a5e" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
          </svg>
        </div>
        <h2 class="cart-empty__title">Your cart is empty</h2>
        <p class="cart-empty__text">You haven't added anything yet. Browse our collection and find something you love.</p>
        <a href="{{ routes.all_products_collection_url }}" class="cart-empty__cta">
          Browse Products
        </a>
      </div>

    {%- endif -%}
  </div>
</section>

<style>
  /* ── Variables ─────────────────────────────────────────── */
  .cart-section {
    --cart-gold: #c49a5e;
    --cart-gold-light: #d4aa6e;
    --cart-dark: #1a1a1a;
    --cart-mid: #444;
    --cart-soft: #888;
    --cart-border: #ebebeb;
    --cart-bg: #fafaf8;
    --cart-panel: #f4f2ee;
    --cart-radius: 12px;
  }

  /* ── Shell ─────────────────────────────────────────────── */
  .cart-section {
    background: var(--cart-bg);
    min-height: 70vh;
    padding: 60px 0 100px;
  }
  .cart-wrap {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Heading row ───────────────────────────────────────── */
  .cart-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  .cart-title {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--cart-dark);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .cart-count-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    height: 32px;
    padding: 0 8px;
    background: var(--cart-gold);
    color: #fff;
    font-size: 0.9rem;
    font-weight: 700;
    border-radius: 999px;
  }
  .cart-continue-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--cart-soft);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 0.2s, gap 0.2s;
  }
  .cart-continue-link:hover {
    color: var(--cart-gold);
    gap: 10px;
  }

  /* ── 2-col form layout ─────────────────────────────────── */
  .cart-body {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 40px;
    align-items: start;
  }

  /* ── Table header ──────────────────────────────────────── */
  .cart-thead {
    display: grid;
    grid-template-columns: 2.5fr 1fr 1fr 1fr;
    padding: 0 0 14px;
    border-bottom: 2px solid var(--cart-dark);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cart-soft);
  }
  .cart-thead .col-price,
  .cart-thead .col-qty,
  .cart-thead .col-total {
    text-align: center;
  }
  .cart-thead .col-total {
    text-align: right;
  }

  /* ── Cart item row ─────────────────────────────────────── */
  @keyframes cart-item-in {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .cart-item {
    display: grid;
    grid-template-columns: 2.5fr 1fr 1fr 1fr;
    align-items: center;
    padding: 24px 0;
    border-bottom: 1px solid var(--cart-border);
    animation: cart-item-in 0.45s both cubic-bezier(0.22, 1, 0.36, 1);
    transition: background 0.2s;
  }
  .cart-item:hover {
    background: linear-gradient(to right, rgba(196,154,94,0.03) 0%, transparent 60%);
  }

  /* Product column = media + details together */
  .cart-item__media {
    width: 120px;
    height: 140px;
    border-radius: 8px;
    overflow: hidden;
    background: #f0ede8;
    flex-shrink: 0;
    transition: transform 0.35s cubic-bezier(0.22,1,0.36,1);
  }
  .cart-item__media:hover {
    transform: scale(1.04);
  }
  .cart-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cart-item__img--placeholder {
    opacity: 0.35;
    padding: 12px;
  }

  /* Make col-product span media + details */
  .cart-item > .cart-item__media,
  .cart-item > .cart-item__details {
    grid-column: 1; /* first column */
  }
  /* Fix: use flex inside the first cell */
  .cart-item {
    display: flex;
    align-items: center;
    gap: 0;
  }
  .cart-item > * {
    flex-shrink: 0;
  }
  /* Override to grid properly */
  .cart-item {
    display: grid;
    grid-template-columns: 120px 1fr 100px 130px 100px;
    gap: 20px;
    align-items: center;
  }

  .cart-item__details {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cart-item__name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--cart-dark);
    text-decoration: none;
    line-clamp: 2;
    -webkit-line-clamp: 2;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.2s;
  }
  .cart-item__name:hover {
    color: var(--cart-gold);
  }
  .cart-item__variant {
    font-size: 0.78rem;
    color: var(--cart-soft);
    margin: 0;
  }
  .cart-item__unit-price {
    font-size: 0.85rem;
    color: var(--cart-mid);
    margin: 2px 0 0;
    display: none; /* shown on mobile */
  }
  .cart-item__remove {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #bbb;
    text-decoration: none;
    margin-top: 8px;
    width: fit-content;
    transition: color 0.2s;
  }
  .cart-item__remove:hover {
    color: #e05252;
  }

  .cart-item__price {
    font-size: 0.95rem;
    color: var(--cart-mid);
    text-align: center;
  }

  /* ── Qty control ───────────────────────────────────────── */
  .cart-item__qty {
    display: flex;
    justify-content: center;
  }
  .qty-control {
    display: inline-flex;
    align-items: center;
    border: 1.5px solid var(--cart-border);
    border-radius: 999px;
    overflow: hidden;
    background: #fff;
    transition: border-color 0.2s;
  }
  .qty-control:focus-within {
    border-color: var(--cart-gold);
  }
  .qty-btn {
    width: 34px;
    height: 36px;
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 1.1rem;
    color: var(--cart-mid);
    transition: background 0.2s, color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .qty-btn:hover {
    background: var(--cart-gold);
    color: #fff;
  }
  .qty-input {
    width: 40px;
    border: none;
    background: transparent;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--cart-dark);
    -moz-appearance: textfield;
    padding: 0;
  }
  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
  }
  .qty-input:focus {
    outline: none;
  }

  .cart-item__line-total {
    font-size: 1rem;
    font-weight: 700;
    color: var(--cart-dark);
    text-align: right;
  }

  /* ── Summary panel ─────────────────────────────────────── */
  .cart-summary-col {
    position: sticky;
    top: 90px;
  }
  .cart-summary-panel {
    background: var(--cart-panel);
    border-radius: var(--cart-radius);
    padding: 28px 24px;
    border: 1px solid rgba(196,154,94,0.15);
  }
  .summary-title {
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--cart-dark);
    margin: 0 0 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--cart-border);
  }
  .summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.95rem;
    color: var(--cart-mid);
    margin-bottom: 10px;
  }
  .summary-amount {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--cart-dark);
  }
  .summary-shipping {
    font-size: 0.78rem;
    color: var(--cart-soft);
    margin: 0 0 20px;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .checkout-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 15px 20px;
    background: var(--cart-gold);
    color: #fff;
    border: none;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
    margin-bottom: 10px;
  }
  .checkout-cta:hover {
    background: var(--cart-gold-light);
    transform: translateY(-3px);
    box-shadow: 0 16px 32px rgba(196,154,94,0.35);
  }
  .checkout-cta:active {
    transform: translateY(-1px);
  }

  .update-cart-btn {
    display: block;
    width: 100%;
    padding: 12px 20px;
    background: transparent;
    color: var(--cart-mid);
    border: 1.5px solid var(--cart-border);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    margin-bottom: 20px;
  }
  .update-cart-btn:hover {
    border-color: var(--cart-dark);
    color: var(--cart-dark);
    background: rgba(0,0,0,0.03);
  }

  /* ── Trust badges ──────────────────────────────────────── */
  .cart-trust {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 16px 0;
    border-top: 1px solid var(--cart-border);
    margin-bottom: 16px;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--cart-mid);
  }
  .trust-item svg {
    color: var(--cart-gold);
    flex-shrink: 0;
  }

  /* ── Cart note ─────────────────────────────────────────── */
  .cart-note-wrap {
    border-top: 1px solid var(--cart-border);
    padding-top: 14px;
  }
  .cart-note-toggle {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--cart-mid);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    list-style: none;
    transition: color 0.2s;
  }
  .cart-note-toggle::-webkit-details-marker { display: none; }
  .cart-note-toggle:hover { color: var(--cart-gold); }
  .cart-note-input {
    width: 100%;
    margin-top: 10px;
    padding: 12px;
    border: 1.5px solid var(--cart-border);
    border-radius: 8px;
    font-size: 0.85rem;
    color: var(--cart-dark);
    background: #fff;
    resize: vertical;
    font-family: inherit;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }
  .cart-note-input:focus {
    outline: none;
    border-color: var(--cart-gold);
  }

  /* ── Empty cart ────────────────────────────────────────── */
  @keyframes empty-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-12px); }
  }
  .cart-empty {
    text-align: center;
    padding: 80px 20px 60px;
  }
  .cart-empty__icon {
    width: 100px;
    height: 100px;
    margin: 0 auto 28px;
    animation: empty-float 3s ease-in-out infinite;
  }
  .cart-empty__icon svg {
    width: 100%;
    height: 100%;
  }
  .cart-empty__title {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--cart-dark);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }
  .cart-empty__text {
    color: var(--cart-soft);
    font-size: 1rem;
    max-width: 360px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }
  .cart-empty__cta {
    display: inline-flex;
    align-items: center;
    padding: 15px 36px;
    background: var(--cart-gold);
    color: #fff;
    text-decoration: none;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .cart-empty__cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 32px rgba(196,154,94,0.35);
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .cart-body {
      grid-template-columns: 1fr 320px;
    }
    .cart-item {
      grid-template-columns: 100px 1fr 90px 120px 90px;
    }
    .cart-item__media {
      width: 100px;
      height: 120px;
    }
  }

  @media (max-width: 900px) {
    .cart-body {
      grid-template-columns: 1fr;
    }
    .cart-summary-col {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .cart-section {
      padding: 40px 0 80px;
    }
    .cart-thead {
      display: none;
    }
    .cart-item {
      grid-template-columns: 90px 1fr;
      grid-template-rows: auto auto auto;
      gap: 12px 16px;
      padding: 20px 0;
    }
    .cart-item__media {
      grid-row: 1 / 3;
      width: 90px;
      height: 110px;
    }
    .cart-item__details {
      grid-column: 2;
    }
    .cart-item__unit-price { display: block; }
    .cart-item__price { display: none; }
    .cart-item__qty {
      grid-column: 2;
      justify-content: flex-start;
    }
    .cart-item__line-total {
      grid-column: 1 / -1;
      text-align: left;
      border-top: 1px dashed var(--cart-border);
      padding-top: 10px;
    }
    .cart-heading { flex-direction: column; gap: 8px; }
  }
</style>

<script>
  document.querySelectorAll('.qty-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var targetId = this.getAttribute('data-target');
      var input = document.getElementById(targetId);
      if (!input) return;
      var current = parseInt(input.value) || 0;
      var delta = this.classList.contains('qty-inc') ? 1 : -1;
      input.value = Math.max(0, current + delta);
    });
  });
</script>

{% schema %}
{
  "name": "Cart Page",
  "settings": [],
  "presets": [
    {
      "name": "Cart Page"
    }
  ]
}
{% endschema %}
