<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}

    <style>
      /* Fix: Shopify-injected password page "Log in here" link fails WCAG 1.4.3.
         #479ccf on #ffffff = 3.03:1 (below the 4.5:1 AA threshold for normal text).
         #1a6fa0 on #ffffff = 5.23:1 — meets AA and ADA/EAA requirements. */
      .content--block .content--desc a,
      .content--block .content--desc span a {
        color: #1a6fa0;
      }
    </style>
  </head>

  <body>
    {{ content_for_layout }}
  </body>
</html>
