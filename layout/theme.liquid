<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}
    <link rel="icon" type="image/png" href="{{ 'favicon.png' | asset_url }}">

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

      {% comment %} Preload the base font variant for initial page render {% endcomment %}
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}

    {{ 'scroll-animations.css' | asset_url | stylesheet_tag }}

    {%- comment -%} Organization JSON-LD — site-wide brand entity signal {%- endcomment -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": "{{ shop.url }}"
      {%- if settings.logo != blank -%}
      ,"logo": "{{ settings.logo | image_url: width: 600 }}"
      {%- endif -%}
    }
    </script>

    {%- if request.page_type == 'index' -%}
    {%- comment -%} WebSite + SearchAction — enables Google sitelinks search box {%- endcomment -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "url": "{{ shop.url }}",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "{{ shop.url }}/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>
    {%- endif -%}
  </head>

  <body>
    <a href="#main-content" class="skip-link">{{ 'general.skip_to_content' | t }}</a>

    {% sections 'header-group' %}

    <main id="main-content" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    <script src="{{ 'scroll-animations.js' | asset_url }}" defer></script>
  </body>
</html>
